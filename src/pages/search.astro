---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Search | Town of Littleton, NH" description="Search the Town of Littleton website for departments, services, news, and more.">

  <main id="main-content">

    <!-- Hero -->
    <section class="bg-navy py-16" aria-labelledby="search-heading">
      <div class="max-w-3xl mx-auto px-8 text-center">
        <p class="text-gold font-semibold uppercase tracking-widest text-sm mb-3">Search</p>
        <h1 id="search-heading" class="text-4xl md:text-5xl font-bold text-white mb-8" style="font-family:'Playfair Display',Georgia,serif;">
          What Are You Looking For?
        </h1>
        <form action="/search" method="get" role="search" class="flex gap-3 max-w-xl mx-auto">
          <label for="hero-search" class="sr-only text-white">Search Town of Littleton</label>
          <input
            type="search"
            id="hero-search"
            name="q"
            placeholder="Search departments, services, news..."
            autocomplete="off"
            class="flex-1 px-5 py-4 bg-white border-2 border-gold rounded-lg text-navy placeholder-gray-400 text-base focus:outline-none focus:ring-2 focus:ring-gold"
          />
          <button
            type="submit"
            class="inline-flex items-center gap-2 bg-gold hover:opacity-90 text-navy font-bold px-6 py-4 rounded-lg transition-opacity focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-navy whitespace-nowrap"
          >
            <svg class="h-5 w-5" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <circle cx="11" cy="11" r="8"/>
              <path d="M21 21l-4.35-4.35"/>
            </svg>
            Search
          </button>
        </form>
      </div>
    </section>

    <!-- Results Section -->
    <section class="py-12 bg-light-blue min-h-[60vh]" aria-label="Search results">
      <div class="max-w-4xl mx-auto px-8">

        <div id="search-status" class="mb-6 min-h-6"></div>
        <div id="search-results-list" aria-live="polite" aria-label="Search results"></div>

        <!-- Quick Links shown when no search -->
        <div id="quick-links">
          <p class="text-sm font-semibold uppercase tracking-widest text-gold mb-4">Quick Links</p>
          <div id="quick-grid">
            <a href="/departments" class="quick-card">
              <div class="quick-icon" aria-hidden="true">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                </svg>
              </div>
              <div>
                <div class="quick-title">Departments</div>
                <div class="quick-desc">Find town departments and contact info</div>
              </div>
            </a>
            <a href="/services" class="quick-card">
              <div class="quick-icon" aria-hidden="true">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                </svg>
              </div>
              <div>
                <div class="quick-title">Services</div>
                <div class="quick-desc">Pay bills, permits, and more</div>
              </div>
            </a>
            <a href="/news" class="quick-card">
              <div class="quick-icon" aria-hidden="true">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
                </svg>
              </div>
              <div>
                <div class="quick-title">News</div>
                <div class="quick-desc">Latest announcements and notices</div>
              </div>
            </a>
            <a href="/contact" class="quick-card">
              <div class="quick-icon" aria-hidden="true">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                  <polyline points="22,6 12,13 2,6"/>
                </svg>
              </div>
              <div>
                <div class="quick-title">Contact Us</div>
                <div class="quick-desc">Get in touch with Town Hall</div>
              </div>
            </a>
          </div>
        </div>

      </div>
    </section>

  </main>

</BaseLayout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  #quick-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .quick-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    padding: 1.25rem;
    text-decoration: none;
    transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
  }
  .quick-card:hover {
    box-shadow: 0 4px 12px rgba(166,122,40,0.15);
    transform: translateY(-1px);
    border-color: #A67A28;
  }

  .quick-icon {
    display: flex;
    height: 2.5rem;
    width: 2.5rem;
    min-width: 2.5rem;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    background: #EEF2F8;
    color: #1B2E4B;
    flex-shrink: 0;
  }
  .quick-icon svg {
    height: 1.25rem;
    width: 1.25rem;
  }

  .quick-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: #1B2E4B;
    margin-bottom: 0.2rem;
  }

  .quick-desc {
    font-size: 0.8rem;
    color: #6b7280;
    line-height: 1.5;
  }

  .result-card {
    display: block;
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    padding: 1.25rem 1.5rem;
    text-decoration: none;
    transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
    margin-bottom: 1rem;
  }
  .result-card:hover {
    box-shadow: 0 4px 12px rgba(166,122,40,0.15);
    transform: translateY(-1px);
    border-color: #A67A28;
  }

  #search-results-list mark {
    background: rgba(166,122,40,0.18);
    color: #78350f;
    border-radius: 2px;
    padding: 0 2px;
    font-style: normal;
  }

  @media (max-width: 640px) {
    #quick-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  async function runSearch() {
    const params = new URLSearchParams(window.location.search);
    const query = params.get('q')?.trim() ?? '';
    const statusEl = document.getElementById('search-status');
    const resultsEl = document.getElementById('search-results-list');
    const quickLinks = document.getElementById('quick-links');
    const heroInput = document.getElementById('hero-search') as HTMLInputElement;

    if (heroInput && query) heroInput.value = query;

    if (!query || !statusEl || !resultsEl || !quickLinks) return;

    resultsEl.style.minHeight = '300px';
    quickLinks.hidden = true;
    statusEl.innerHTML = '<p style="color:#4b5563;font-size:0.9rem;">Searching...</p>';
    resultsEl.innerHTML = `
      <div style="display:flex;flex-direction:column;gap:1rem;">
        ${[1,2,3].map(() => `
          <div style="background:white;border:1px solid #e5e7eb;border-radius:0.75rem;padding:1.25rem 1.5rem;">
            <div style="height:1.25rem;background:#f3f4f6;border-radius:0.25rem;width:40%;margin-bottom:0.5rem;"></div>
            <div style="height:0.75rem;background:#f3f4f6;border-radius:0.25rem;width:25%;margin-bottom:0.75rem;"></div>
            <div style="height:0.875rem;background:#f3f4f6;border-radius:0.25rem;width:90%;margin-bottom:0.375rem;"></div>
            <div style="height:0.875rem;background:#f3f4f6;border-radius:0.25rem;width:75%;"></div>
          </div>
        `).join('')}
      </div>
    `;

    let pagefind: any;
    try {
      // @ts-ignore
      pagefind = await import(/* @vite-ignore */ '/pagefind/pagefind.js');
    } catch {
      statusEl.innerHTML = '<p style="color:#6b7280;font-size:0.9rem;">Search index not available. Try again on the live site.</p>';
      resultsEl.style.minHeight = '0';
      quickLinks.hidden = false;
      return;
    }

    try {
      const results = await pagefind.search(query);
      const data = await Promise.all(results.results.map((r: any) => r.data()));

      if (data.length === 0) {
        statusEl.innerHTML = '';
        resultsEl.innerHTML = `
          <div style="text-align:center;padding:3rem 1.5rem;background:white;border:1px solid #e5e7eb;border-radius:0.75rem;margin-bottom:2rem;">
            <span style="font-size:3rem;display:block;margin-bottom:1rem;">🔍</span>
            <h2 style="font-size:1.25rem;font-weight:700;color:#1B2E4B;margin-bottom:0.5rem;">No results for "${query}"</h2>
            <p style="font-size:0.9rem;color:#6b7280;margin-bottom:1.5rem;">Try a different search term or browse the links below.</p>
            <a href="/departments" style="display:inline-flex;align-items:center;gap:0.5rem;background:#A67A28;color:white;font-weight:700;padding:0.75rem 1.5rem;border-radius:0.5rem;text-decoration:none;font-size:0.9rem;">Browse Departments</a>
          </div>
        `;
        quickLinks.hidden = false;
        return;
      }

      statusEl.innerHTML = `<p style="color:#4b5563;font-size:0.9rem;margin-bottom:1.5rem;"><strong style="color:#1B2E4B;">${data.length}</strong> result${data.length === 1 ? '' : 's'} for "<strong style="color:#78350f;">${query}</strong>"</p>`;

      resultsEl.innerHTML = data.map((item: any) => `
        <a href="${item.url}" style="display:block;background:white;border:1px solid #e5e7eb;border-left:4px solid #A67A28;border-radius:0.75rem;padding:1.25rem 1.5rem;text-decoration:none;margin-bottom:1rem;">
          <div style="font-size:1.1rem;font-weight:700;color:#1B2E4B;margin-bottom:0.375rem;">${item.meta?.title ?? 'Town of Littleton'}</div>
          <div style="font-size:0.75rem;color:#15803d;margin-bottom:0.5rem;font-weight:500;">premium1.jakefixestech.com${item.url}</div>
          <div style="font-size:0.9rem;color:#4b5563;line-height:1.6;">${item.excerpt ?? ''}</div>
        </a>
      `).join('');
    } catch (err) {
      statusEl.innerHTML = '<p style="color:#6b7280;font-size:0.9rem;">Something went wrong. Please try again.</p>';
      resultsEl.style.minHeight = '0';
      quickLinks.hidden = false;
    }
  }

  runSearch();
</script>