---
import BaseLayout from '../layouts/BaseLayout.astro';

const builtPages = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
  { label: 'Town History', href: '/about/history' },
  { label: 'Officials & Staff', href: '/about/officials' },
  { label: 'Government Hub', href: '/government' },
  { label: 'Selectboard', href: '/government/selectboard' },
  { label: 'Meeting Minutes', href: '/government/meeting-minutes' },
  { label: 'Budget & Finance', href: '/government/budget' },
  { label: 'Town Charter', href: '/government/charter' },
  { label: 'Annual Reports', href: '/government/annual-reports' },
  { label: 'Departments', href: '/departments' },
  { label: 'Town Clerk', href: '/departments/town-clerk' },
  { label: 'Public Works', href: '/departments/public-works' },
  { label: 'Planning & Zoning', href: '/departments/planning-zoning' },
  { label: 'Police', href: '/departments/police' },
  { label: 'Fire', href: '/departments/fire' },
  { label: 'Finance', href: '/departments/finance' },
  { label: 'Library', href: '/departments/library' },
  { label: 'Emergency Management', href: '/departments/emergency-management' },
  { label: 'Services', href: '/services' },
  { label: 'Pay a Bill', href: '/services/pay' },
  { label: 'Permits & Licenses', href: '/services/permits' },
  { label: 'Report a Problem', href: '/services/report' },
  { label: 'Public Records', href: '/services/public-records' },
  { label: 'Voting & Elections', href: '/services/voting' },
  { label: 'Trash & Recycling', href: '/services/trash' },
  { label: 'News', href: '/news' },
  { label: 'Calendar', href: '/calendar' },
  { label: 'Accessibility', href: '/accessibility' },
  { label: 'Privacy Policy', href: '/privacy' },
  { label: 'Site Map', href: '/sitemap' },
];
---

<BaseLayout title="Demo Page | Town of Littleton, NH" description="This is a portfolio demonstration site built by Jake Fixes Tech.">

  <!-- Hero -->
  <section aria-labelledby="hero-heading" class="bg-navy py-16 text-center">
    <div class="max-w-4xl mx-auto px-8">
      <div class="demo-badge">Portfolio Demo</div>
      <h1 id="hero-heading" class="text-4xl font-bold text-white mb-4">
        This Page Is Part of a Demo
      </h1>
      <p class="text-xl text-white max-w-2xl mx-auto leading-relaxed" style="opacity: 0.9;">
        In a real implementation, this page would contain full content tailored to your town's needs.
        This site was built to demonstrate what a modern, accessible municipal website can look like.
      </p>
    </div>
  </section>

  <!-- What This Demo Shows -->
  <section aria-labelledby="demo-heading" class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-8">
      <h2 id="demo-heading" class="text-3xl font-bold text-navy text-center mb-10">What This Demo Includes</h2>
      <div class="features-grid">

        <div class="feature-card">
          <div class="feature-icon">
            <svg aria-hidden="true" class="w-7 h-7 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-navy mb-2">30+ Fully Built Pages</h3>
          <p class="text-body-text text-sm">Every major section of a municipal website — departments, services, government, news, and more.</p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">
            <svg aria-hidden="true" class="w-7 h-7 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-navy mb-2">WCAG 2.1 AA Accessible</h3>
          <p class="text-body-text text-sm">Full keyboard navigation, screen reader support, proper heading hierarchy, and ARIA labels throughout.</p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">
            <svg aria-hidden="true" class="w-7 h-7 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-navy mb-2">Fully Responsive</h3>
          <p class="text-body-text text-sm">Looks great on every device — desktop, tablet, and mobile — with no separate mobile site needed.</p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">
            <svg aria-hidden="true" class="w-7 h-7 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-navy mb-2">Lightning Fast</h3>
          <p class="text-body-text text-sm">Built with Astro — pages are static HTML with no JavaScript overhead. Near-perfect Lighthouse scores.</p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">
            <svg aria-hidden="true" class="w-7 h-7 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-navy mb-2">SEO Ready</h3>
          <p class="text-body-text text-sm">Proper meta descriptions, semantic HTML, sitemap, and page titles on every single page.</p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">
            <svg aria-hidden="true" class="w-7 h-7 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-navy mb-2">Built for NH Towns</h3>
          <p class="text-body-text text-sm">RSA 91-A compliance, NH SOS voting links, real local context — not a generic template.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Built Pages Directory -->
  <section aria-labelledby="pages-heading" class="py-16 bg-light-blue">
    <div class="max-w-4xl mx-auto px-8">
      <h2 id="pages-heading" class="text-3xl font-bold text-navy text-center mb-4">Fully Built Pages</h2>
      <p class="text-body-text text-center mb-8">Every one of these pages is complete, accessible, and live:</p>
      <ul class="pages-list">
        {builtPages.map((page) => (
          <li>
            <a href={page.href} class="page-link">
              <span aria-hidden="true" class="page-arrow">›</span>
              {page.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section aria-labelledby="cta-heading" class="py-16 bg-navy text-center">
    <div class="max-w-3xl mx-auto px-8">
      <h2 id="cta-heading" class="text-3xl font-bold text-white mb-4">
        Want a Website Like This for Your Town?
      </h2>
      <p class="text-white mb-8 leading-relaxed" style="opacity: 0.9;">
        Jake Fixes Tech builds modern, accessible, fast websites for NH municipalities and small businesses.
        Starting at a flat project rate — no monthly fees, no surprises.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="https://jakefixestech.com"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block bg-gold text-navy font-bold px-8 py-4 rounded-lg text-lg hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2"
        >
          Visit jakefixestech.com
        </a>
        <a
          href="https://jakefixestech.com/contact/"
          class="inline-block bg-white text-navy font-bold px-8 py-4 rounded-lg text-lg hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2"
        >
          Get in Touch
        </a>
      </div>
      <p class="text-white text-sm mt-8" style="opacity: 0.6;">
        This is a portfolio demonstration site. It is not affiliated with the actual Town of Littleton, NH.
      </p>
    </div>
  </section>

</BaseLayout>

<style>
  .demo-badge {
    display: inline-block;
    background-color: #C8973A;
    color: #1B2E4B;
    font-weight: 700;
    font-size: 0.875rem;
    padding: 4px 16px;
    border-radius: 999px;
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  @media (max-width: 900px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .features-grid { grid-template-columns: 1fr; }
  }

  .feature-card {
    background: #EEF2F8;
    border-radius: 8px;
    padding: 24px;
  }

  .feature-icon {
    width: 48px;
    height: 48px;
    background: white;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 12px;
  }

  .pages-list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    list-style: none;
    padding: 24px;
    margin: 0;
    background: white;
    border-radius: 12px;
  }
  @media (max-width: 768px) {
    .pages-list { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 500px) {
    .pages-list { grid-template-columns: 1fr; }
  }

  .page-link {
    display: flex;
    align-items: center;
    gap: 6px;
    color: #1B2E4B;
    text-decoration: none;
    font-size: 0.9rem;
    padding: 6px 8px;
    border-radius: 4px;
    transition: background-color 0.15s;
  }
  .page-link:hover { background-color: #EEF2F8; }
  .page-link:focus {
    outline: 2px solid #1B2E4B;
    outline-offset: 2px;
  }

  /* Fixed: navy on white passes contrast — was gold #C8973A which failed */
  .page-arrow {
    color: #1B2E4B;
    font-weight: bold;
    font-size: 1.1rem;
  }
</style>