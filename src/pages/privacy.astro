---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Privacy Policy | Town of Littleton, NH" description="Privacy policy for the official Town of Littleton, New Hampshire municipal website.">

  <!-- Hero -->
  <section aria-labelledby="hero-heading" class="bg-light-blue py-12 text-center">
    <div class="max-w-7xl mx-auto px-8">
      <h2 id="hero-heading" class="text-4xl font-bold text-navy mb-2">Privacy Policy</h2>
      <p class="text-body-text text-lg">Last updated: October 2025</p>
    </div>
  </section>

  <!-- Introduction -->
  <section aria-labelledby="introduction-heading" class="bg-white py-12">
    <div class="prose-section">
      <h2 id="introduction-heading" class="section-heading">Introduction</h2>
      <p class="prose-text mb-4">
        Welcome to the official website of the Town of Littleton, New Hampshire. This Privacy Policy describes how we collect, use, and protect information gathered through our municipal website and online services. We are committed to safeguarding the privacy of our residents and visitors.
      </p>
      <p class="prose-text">
        This policy applies to all information collected through littletonnh.gov and any associated online forms, applications, or services provided by the Town of Littleton. By using our website, you consent to the practices described in this policy.
      </p>
    </div>
  </section>

  <!-- Information We Collect -->
  <section aria-labelledby="collect-heading" class="bg-light-blue py-12">
    <div class="prose-section">
      <h2 id="collect-heading" class="section-heading">Information We Collect</h2>

      <h3 class="subsection-heading">Information You Provide</h3>
      <p class="prose-text mb-3">
        When you use our contact forms, sign up for email notifications, or submit permit applications, you may provide us with personal information including:
      </p>
      <ul class="prose-list">
        <li>Name and contact information (address, email, phone number)</li>
        <li>Property information for permit and tax-related services</li>
        <li>Payment information for online transactions</li>
        <li>Documents uploaded for permit applications</li>
        <li>Comments or questions submitted through contact forms</li>
      </ul>

      <h3 class="subsection-heading mt-6">Automatically Collected Information</h3>
      <p class="prose-text mb-3">
        When you visit our website, certain information is automatically collected through server logs and analytics tools:
      </p>
      <ul class="prose-list">
        <li>IP address and browser type</li>
        <li>Device type and operating system</li>
        <li>Pages visited and time spent on each page</li>
        <li>Referring website or search terms used</li>
        <li>Date and time of your visit</li>
      </ul>
    </div>
  </section>

  <!-- How We Use Information -->
  <section aria-labelledby="use-heading" class="bg-white py-12">
    <div class="prose-section">
      <h2 id="use-heading" class="section-heading">How We Use Your Information</h2>
      <p class="prose-text mb-3">The Town of Littleton uses collected information for the following purposes:</p>
      <ul class="prose-list">
        <li>Respond to your inquiries and service requests</li>
        <li>Process permit and license applications</li>
        <li>Send requested notifications and alerts</li>
        <li>Improve website functionality and user experience</li>
        <li>Comply with legal obligations</li>
        <li>Analyze website usage through aggregate statistics</li>
      </ul>
    </div>
  </section>

  <!-- Information Sharing -->
  <section aria-labelledby="sharing-heading" class="bg-light-blue py-12">
    <div class="prose-section">
      <h2 id="sharing-heading" class="section-heading">Information Sharing</h2>
      <p class="prose-text mb-4">
        The Town of Littleton does not sell, trade, or rent your personal information to third parties for marketing purposes.
      </p>
      <p class="prose-text mb-3">We may share your information in the following circumstances:</p>
      <ul class="prose-list mb-4">
        <li>With state agencies as required for regulatory compliance</li>
        <li>With law enforcement when required by law or court order</li>
        <li>With contracted service providers who assist in delivering town services</li>
      </ul>
      <p class="prose-text italic">
        Please note: As a municipal government, the Town of Littleton is subject to New Hampshire RSA 91-A, the Right to Know Law. Certain records may be subject to public disclosure upon request, except where exemptions apply.
      </p>
    </div>
  </section>

  <!-- Cookies -->
  <section aria-labelledby="cookies-heading" class="bg-white py-12">
    <div class="prose-section">
      <h2 id="cookies-heading" class="section-heading">Cookies &amp; Analytics</h2>
      <p class="prose-text mb-4">
        Our website uses cookies — small text files stored on your device — to enhance your browsing experience. Cookies help us remember your preferences and understand how visitors use our site.
      </p>
      <p class="prose-text mb-4">
        We use Google Analytics to collect aggregate information about website traffic and usage patterns. This helps us improve our services and better serve our community. Google Analytics uses cookies to gather anonymous data about your visit.
      </p>
      <p class="prose-text">
        You can opt out of Google Analytics by installing the
        <a
          href="https://tools.google.com/dlpage/gaoptout"
          target="_blank"
          rel="noopener noreferrer"
          class="text-navy underline hover:no-underline focus:outline-none focus:ring-2 focus:ring-gold focus:ring-offset-2 rounded"
        >
          Google Analytics Opt-out Browser Add-on
        </a>.
        You can also configure your browser settings to reject cookies, though this may limit some website functionality.
      </p>
    </div>
  </section>

  <!-- Your Rights -->
  <section aria-labelledby="rights-heading" class="bg-light-blue py-12">
    <div class="prose-section">
      <h2 id="rights-heading" class="section-heading">Your Rights</h2>
      <p class="prose-text mb-3">
        New Hampshire residents have certain rights regarding their personal information held by municipal governments:
      </p>
      <ul class="prose-list mb-4">
        <li><strong>Right to Access:</strong> You may request a copy of the personal information we hold about you.</li>
        <li><strong>Right to Correct:</strong> You may request corrections to inaccurate or incomplete information.</li>
        <li><strong>Right to Delete:</strong> In certain circumstances, you may request deletion of your personal information, subject to legal retention requirements.</li>
      </ul>
      <p class="prose-text">
        To submit a request regarding your personal information, please visit our
        <a
          href="/contact"
          class="text-navy underline hover:no-underline focus:outline-none focus:ring-2 focus:ring-gold focus:ring-offset-2 rounded"
        >
          Contact page
        </a>
        or reach out to the Town Clerk's office.
      </p>
    </div>
  </section>

  <!-- Contact -->
  <section aria-labelledby="contact-heading" class="bg-white py-12">
    <div class="max-w-3xl mx-auto px-8 text-center">
      <h2 id="contact-heading" class="text-3xl font-bold text-navy mb-6">Contact Us About This Policy</h2>
      <div class="contact-box">
        <p class="text-body-text mb-3">
          <strong class="text-navy">Email: </strong>
          <a
            href="mailto:privacy@littletonnh.gov"
            class="text-navy underline hover:no-underline focus:outline-none focus:ring-2 focus:ring-gold focus:ring-offset-2 rounded"
          >
            privacy@littletonnh.gov
          </a>
        </p>
        <p class="text-body-text">
          <strong class="text-navy">Phone: </strong>
          <a
            href="tel:+16035550100"
            class="text-navy underline hover:no-underline focus:outline-none focus:ring-2 focus:ring-gold focus:ring-offset-2 rounded"
            aria-label="Call (603) 555-0100"
          >
            (603) 555-0100
          </a>
        </p>
      </div>
      <a
        href="/contact"
        class="inline-block bg-navy text-white px-8 py-3 rounded font-semibold hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 mt-6"
      >
        Contact Us
      </a>
    </div>
  </section>

  <!-- Changes -->
  <section aria-labelledby="changes-heading" class="bg-light-blue py-12">
    <div class="prose-section">
      <h2 id="changes-heading" class="section-heading">Changes to This Policy</h2>
      <p class="prose-text mb-4">
        The Town of Littleton may update this Privacy Policy from time to time to reflect changes in our practices or legal requirements. When we make significant changes, we will update the "Last updated" date at the top of this page.
      </p>
      <p class="prose-text">
        Your continued use of our website after any changes to this policy constitutes your acceptance of the updated terms. We encourage you to review this policy periodically.
      </p>
    </div>
  </section>

</BaseLayout>

<style>
  .prose-section {
    max-width: 48rem;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-heading {
    font-size: 1.875rem;
    font-weight: 700;
    color: #1B2E4B;
    margin-bottom: 1.5rem;
  }

  .subsection-heading {
    font-size: 1.25rem;
    font-weight: 600;
    color: #1B2E4B;
    margin-bottom: 0.75rem;
  }

  .prose-text {
    color: #1E2D3D;
    line-height: 1.7;
  }

  .prose-list {
    list-style: disc;
    padding-left: 1.5rem;
    color: #1E2D3D;
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .prose-list li {
    margin-bottom: 0.5rem;
  }

  .contact-box {
    background-color: #EEF2F8;
    padding: 1.5rem 2rem;
    border-radius: 8px;
    display: inline-block;
    text-align: left;
    margin-bottom: 8px;
  }
</style>