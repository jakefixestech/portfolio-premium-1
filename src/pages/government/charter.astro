---
import BaseLayout from '../../layouts/BaseLayout.astro';

const ordinances = [
  { title: 'Zoning Ordinances', description: 'Land use regulations governing property development, lot sizes, setbacks, and permitted uses in each zoning district.' },
  { title: 'Building Codes', description: 'Construction standards and requirements for new buildings, renovations, and structural modifications.' },
  { title: 'Traffic & Parking', description: 'Local traffic rules, parking regulations, speed limits, and signage requirements for town roads.' },
  { title: 'Health & Safety', description: 'Public health regulations including food service, septic systems, noise ordinances, and nuisance abatement.' },
  { title: 'Business Licensing', description: 'Requirements for operating a business in Littleton, including permits, licenses, and registration procedures.' },
  { title: 'Environmental', description: 'Protecting natural resources including wetlands protection, stormwater management, and tree preservation.' },
];

const amendments = [
  { datetime: '2025-03-11', date: 'March 11, 2025', description: 'Zoning amendment for accessory dwelling units in residential districts' },
  { datetime: '2024-11-05', date: 'November 5, 2024', description: 'Updated parking requirements for downtown commercial zone' },
  { datetime: '2024-03-12', date: 'March 12, 2024', description: 'Noise ordinance amendment extending quiet hours' },
  { datetime: '2023-11-07', date: 'November 7, 2023', description: 'Short-term rental registration and licensing requirements' },
];
---

<BaseLayout title="Town Charter & Ordinances | Town of Littleton, NH" description="The governing documents of the Town of Littleton, including the Town Charter, zoning ordinances, and local regulations.">

  <!-- Hero -->
  <section aria-labelledby="hero-heading" class="bg-light-blue py-16">
    <div class="max-w-7xl mx-auto px-8">
      <nav aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 text-sm text-body-text mb-4 list-none p-0 m-0">
          <li>
            <a href="/government" class="hover:underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded">
              Government
            </a>
          </li>
          <li aria-hidden="true">/</li>
          <li aria-current="page" class="text-navy font-medium">Town Charter</li>
        </ol>
      </nav>
      <h2 id="hero-heading" class="text-4xl font-bold text-navy mb-4">Town Charter &amp; Ordinances</h2>
      <p class="text-xl text-body-text max-w-3xl">
        The governing documents of the Town of Littleton, including the Town Charter, zoning ordinances, and local regulations.
      </p>
    </div>
  </section>

  <!-- Town Charter -->
  <section aria-labelledby="charter-heading" class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-8 text-center">
      <h2 id="charter-heading" class="text-3xl font-bold text-navy mb-8">Town Charter</h2>
      <p class="text-body-text mb-6 leading-relaxed">
        The Town Charter serves as the constitution for the Town of Littleton, establishing the framework
        for local government, defining the powers and responsibilities of elected officials, and outlining
        the rights of residents. Originally adopted in 1969, the charter has been amended several times
        to reflect the evolving needs of our community.
      </p>
      <p class="text-body-text mb-8 leading-relaxed">
        The charter establishes our Select Board form of government, creates the positions of Town Manager
        and Town Clerk, and defines the procedures for town meetings, elections, and the adoption of local
        ordinances. All town officials and employees are bound by its provisions.
      </p>
      <a
        href="#"
        class="inline-block bg-navy text-white font-semibold px-6 py-3 rounded hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2"
        aria-label="Download Town Charter PDF"
      >
        Download Town Charter PDF <span aria-hidden="true">→</span>
      </a>
      <p class="text-sm text-body-text mt-4">Last amended: 2019</p>
    </div>
  </section>

  <!-- Ordinances -->
  <section aria-labelledby="ordinances-heading" class="py-16 bg-light-blue">
    <div class="max-w-7xl mx-auto px-8">
      <h2 id="ordinances-heading" class="text-3xl font-bold text-navy text-center mb-8">Town Ordinances</h2>
      <div class="ord-grid">
        {ordinances.map((ord) => (
          <article class="ord-card">
            <h3 class="text-xl font-bold text-navy mb-3">{ord.title}</h3>
            <p class="text-body-text mb-4">{ord.description}</p>
            <a
              href="#"
              class="text-navy font-semibold underline hover:no-underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded"
              aria-label={`View ${ord.title}`}
            >
              View <span aria-hidden="true">→</span>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Amendments -->
  <section aria-labelledby="amendments-heading" class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-8">
      <h2 id="amendments-heading" class="text-3xl font-bold text-navy text-center mb-8">Recent Amendments</h2>
      <div class="overflow-x-auto">
        <table class="amendments-table">
          <caption class="sr-only">Recent amendments to town ordinances and their adoption status</caption>
          <thead>
            <tr>
              <th scope="col">Date</th>
              <th scope="col">Description</th>
              <th scope="col">Status</th>
            </tr>
          </thead>
          <tbody>
            {amendments.map((a, i) => (
              <tr class={i % 2 === 0 ? 'row-white' : 'row-light'}>
                <td class="whitespace-nowrap">
                  <time datetime={a.datetime}>{a.date}</time>
                </td>
                <td>{a.description}</td>
                <td><span class="status-badge">Adopted</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section aria-labelledby="contact-heading" class="py-16 bg-light-blue">
    <div class="max-w-3xl mx-auto px-8 text-center">
      <h2 id="contact-heading" class="text-3xl font-bold text-navy mb-4">Questions About Town Regulations?</h2>
      <p class="text-body-text mb-8 leading-relaxed">
        The Town Clerk's office can help you find specific ordinances, understand regulations,
        and guide you through the amendment process.
      </p>
      <a
        href="/departments/town-clerk"
        class="inline-block bg-navy text-white font-semibold px-6 py-3 rounded hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2"
      >
        Contact Town Clerk <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  .ord-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 1200px;
    margin: 40px auto;
    padding: 0 32px;
  }
  @media (max-width: 768px) {
    .ord-grid { grid-template-columns: 1fr; }
  }

  .ord-card {
    background: white;
    border-top: 4px solid #2C4A7C;
    padding: 24px;
    border-radius: 8px;
  }

  .amendments-table {
    width: 100%;
    border-collapse: collapse;
    background: white;
    border-radius: 8px;
    overflow: hidden;
  }
  .amendments-table thead {
    background-color: #1B2E4B;
  }
  .amendments-table th {
    color: white;
    font-weight: 600;
    text-align: left;
    padding: 12px 16px;
  }
  .amendments-table td {
    padding: 12px 16px;
    color: #1E2D3D;
    border-bottom: 1px solid #EEF2F8;
  }
  .amendments-table tbody tr:last-child td {
    border-bottom: none;
  }
  .row-white { background-color: white; }
  .row-light { background-color: #EEF2F8; }

  .status-badge {
    display: inline-block;
    background-color: #EEF2F8;
    color: #1B2E4B;
    padding: 2px 10px;
    border-radius: 4px;
    font-size: 0.875rem;
    font-weight: 600;
    border: 1px solid #2C4A7C;
  }
</style>