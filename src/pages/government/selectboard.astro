---
import BaseLayout from '../../layouts/BaseLayout.astro';

const boardMembers = [
  { name: 'Margaret Sullivan', title: 'Chair', term: '2026' },
  { name: 'Robert Kenney', title: 'Vice Chair', term: '2027' },
  { name: 'Patricia Bouchard', title: 'Member', term: '2025' },
  { name: 'Thomas Gagnon', title: 'Member', term: '2026' },
  { name: 'Linda Whitcomb', title: 'Member', term: '2027' },
];

const upcomingMeetings = [
  { date: 'November 4, 2025', datetime: '2025-11-04', time: '6:00 PM', location: 'Town Hall, Meeting Room A' },
  { date: 'November 18, 2025', datetime: '2025-11-18', time: '6:00 PM', location: 'Town Hall, Meeting Room A' },
  { date: 'December 2, 2025', datetime: '2025-12-02', time: '6:00 PM', location: 'Town Hall, Meeting Room A' },
  { date: 'December 16, 2025', datetime: '2025-12-16', time: '6:00 PM', location: 'Town Hall, Meeting Room A' },
  { date: 'January 6, 2026', datetime: '2026-01-06', time: '6:00 PM', location: 'Town Hall, Meeting Room A' },
];

const executivePowers = [
  'Appoint town administrator and department heads',
  'Set town policy and strategic direction',
  'Approve contracts and expenditures',
  'Manage town-owned property',
  'Execute all legal documents on behalf of town',
];

const legislativePowers = [
  'Prepare and present annual budget',
  'Set tax rates in conjunction with state',
  'Enact local ordinances and regulations',
  'Call special town meetings',
  'Respond to citizen petitions',
];
---

<BaseLayout title="Selectboard | Town of Littleton, NH" description="The Littleton Selectboard is the five-member elected body responsible for the overall management and policy direction of town government.">

  <!-- Hero -->
  <section class="bg-light-blue py-12" aria-labelledby="hero-heading">
    <div class="max-w-7xl mx-auto px-8">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-sm text-body-text list-none p-0 m-0">
          <li>
            <a href="/government" class="hover:underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded">
              Government
            </a>
          </li>
          <li aria-hidden="true">/</li>
          <li aria-current="page" class="text-navy font-medium">Selectboard</li>
        </ol>
      </nav>
      <h2 id="hero-heading" class="text-4xl font-bold text-navy mb-4">Selectboard</h2>
      <p class="text-lg text-body-text max-w-3xl mb-6">
        The Littleton Selectboard is the five-member elected body responsible for the overall
        management and policy direction of town government.
      </p>
      <div class="flex items-center gap-2 text-body-text">
        <svg class="w-5 h-5 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        <span>Meets every other Tuesday at 6:00 PM &mdash; Town Hall, Meeting Room A</span>
      </div>
    </div>
  </section>

  <!-- Board Members -->
  <section class="py-12 bg-white" aria-labelledby="members-heading">
    <div class="max-w-7xl mx-auto px-8 text-center">
      <h2 id="members-heading" class="text-3xl font-bold text-navy mb-2">Board Members</h2>
    </div>
    <div class="members-grid">
      {boardMembers.map((member) => (
        <div class="bg-light-blue rounded-lg p-6 text-center">
          <div class="w-16 h-16 bg-mid-blue rounded-full mx-auto mb-4 flex items-center justify-center">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
          </div>
          <h3 class="font-semibold text-navy">{member.name}</h3>
          <p class="text-navy font-medium text-sm">{member.title}</p>
          <p class="text-body-text text-sm mt-1">Term ends {member.term}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Upcoming Meetings -->
  <section class="py-12 bg-light-blue" aria-labelledby="meetings-heading">
    <div class="max-w-7xl mx-auto px-8">
      <h2 id="meetings-heading" class="text-3xl font-bold text-navy text-center mb-8">Upcoming Meetings</h2>
      <div class="overflow-x-auto">
        <table class="meetings-table">
          <caption class="sr-only">Upcoming Selectboard meetings schedule</caption>
          <thead>
            <tr>
              <th scope="col">Date</th>
              <th scope="col">Time</th>
              <th scope="col">Location</th>
              <th scope="col">Agenda</th>
            </tr>
          </thead>
          <tbody>
            {upcomingMeetings.map((meeting) => (
              <tr>
                <td>
                  <time datetime={meeting.datetime}>{meeting.date}</time>
                </td>
                <td>{meeting.time}</td>
                <td>{meeting.location}</td>
                <td>
                  <a
                    href="#"
                    class="text-navy font-medium hover:underline focus:outline-none focus:ring-2 focus:ring-gold focus:ring-offset-2 rounded"
                    aria-label={`Download agenda for ${meeting.date} Selectboard meeting`}
                  >
                    Download <span aria-hidden="true">→</span>
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Responsibilities -->
  <section class="py-12 bg-white" aria-labelledby="responsibilities-heading">
    <div class="max-w-7xl mx-auto px-8 text-center">
      <h2 id="responsibilities-heading" class="text-3xl font-bold text-navy mb-2">Selectboard Responsibilities</h2>
    </div>
    <div class="resp-grid">
      <div>
        <h3 class="text-xl font-semibold text-navy mb-4">Executive Powers</h3>
        <ul class="space-y-3 list-none p-0 m-0">
          {executivePowers.map((power) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-mid-blue mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="text-body-text">{power}</span>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="text-xl font-semibold text-navy mb-4">Legislative Powers</h3>
        <ul class="space-y-3 list-none p-0 m-0">
          {legislativePowers.map((power) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-mid-blue mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="text-body-text">{power}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Public Participation -->
  <section class="py-12 bg-light-blue" aria-labelledby="participation-heading">
    <div class="max-w-7xl mx-auto px-8 text-center">
      <h2 id="participation-heading" class="text-3xl font-bold text-navy mb-4">Public Participation</h2>
      <p class="text-body-text max-w-2xl mx-auto mb-8">
        The Selectboard welcomes public input and participation at all meetings. A public comment
        period is held at the beginning of each meeting, and citizens may also request to be added
        to the agenda for specific topics.
      </p>
    </div>
    <div class="participation-grid">
      <div class="bg-white rounded-lg p-6">
        <h3 class="text-lg font-semibold text-navy mb-3">Attend a Meeting</h3>
        <p class="text-body-text text-sm">
          All Selectboard meetings are open to the public. Meetings are held every other Tuesday
          at 6:00 PM in Town Hall, Meeting Room A. A public comment period is available at the
          start of each meeting for residents to address the board.
        </p>
      </div>
      <div class="bg-white rounded-lg p-6">
        <h3 class="text-lg font-semibold text-navy mb-3">Submit Written Comment</h3>
        <p class="text-body-text text-sm mb-4">
          Written comments may be submitted before any meeting and will be distributed to all
          board members. Comments should be received by 12:00 PM on the day of the meeting.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 bg-navy text-white px-4 py-2 rounded font-medium hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2"
          aria-label="Contact the Selectboard"
        >
          Contact the Board <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Meeting Archive -->
  <section class="py-12 bg-white" aria-labelledby="archive-heading">
    <div class="max-w-7xl mx-auto px-8 text-center">
      <h2 id="archive-heading" class="text-3xl font-bold text-navy mb-4">Meeting Minutes Archive</h2>
      <p class="text-body-text max-w-2xl mx-auto mb-6">
        All Selectboard meeting minutes are available for public review. Minutes are typically
        approved at the following meeting and posted within one week of approval.
      </p>
      <a
        href="/government/meeting-minutes"
        class="inline-flex items-center gap-2 bg-navy text-white px-6 py-3 rounded font-semibold hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2"
        aria-label="View all Selectboard meeting minutes"
      >
        View All Minutes <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .members-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
    max-width: 1200px;
    margin: 40px auto;
    padding: 0 32px;
  }
  @media (max-width: 900px) {
    .members-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    .members-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .meetings-table {
    width: 100%;
    border-collapse: collapse;
    background: white;
    border-radius: 8px;
    overflow: hidden;
  }
  .meetings-table thead {
    background: #1B2E4B;
  }
  .meetings-table th {
    color: white;
    font-weight: 600;
    text-align: left;
    padding: 12px 16px;
  }
  .meetings-table td {
    padding: 12px 16px;
    border-bottom: 1px solid #EEF2F8;
    color: #1E2D3D;
  }
  .meetings-table tbody tr:last-child td {
    border-bottom: none;
  }
  .meetings-table tbody tr:nth-child(even) {
    background: #f9faf9;
  }

  .resp-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    max-width: 1200px;
    margin: 40px auto;
    padding: 0 32px;
  }
  @media (max-width: 768px) {
    .resp-grid { grid-template-columns: 1fr; }
  }

  .participation-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    max-width: 800px;
    margin: 32px auto;
    padding: 0 32px;
  }
  @media (max-width: 600px) {
    .participation-grid { grid-template-columns: 1fr; }
  }
</style>