---
import BaseLayout from '../../layouts/BaseLayout.astro';

const timelineEvents = [
  { year: '1764', description: 'Littleton was officially incorporated as a town, named after Colonel Moses Little of Newbury, Massachusetts. The first settlers arrived seeking fertile land along the Ammonoosuc River.' },
  { year: '1820', description: 'The railroad arrived in Littleton, transforming the small agricultural community into a thriving commercial center. Mills and factories soon followed, bringing prosperity to the region.' },
  { year: '1905', description: 'The Littleton Coin Company was founded, beginning what would become one of the largest coin dealers in the United States and a major employer in the community.' },
  { year: '1940', description: 'During World War II, Littleton residents contributed significantly to the war effort through manufacturing, Victory Gardens, and community support programs.' },
  { year: '1980', description: 'A major downtown revitalization effort began, restoring historic buildings along Main Street and establishing Littleton as a destination for visitors to the White Mountains.' },
  { year: '2010', description: 'An arts and culture renaissance took hold, with new galleries, restaurants, and cultural events establishing Littleton as the creative hub of northern New Hampshire.' },
];

const landmarks = [
  { name: 'Littleton Opera House', description: 'Built in 1894, this beautifully restored Victorian theater continues to host performances and community events on Main Street.' },
  { name: 'Covered Bridge', description: 'This historic covered bridge on Elm Street is one of the few remaining examples of 19th-century bridge construction in the region.' },
  { name: 'Littleton Grist Mill', description: 'The original 1798 mill site where early settlers ground their grain, now preserved as a testament to the town\'s agricultural heritage.' },
];

const quickFacts = [
  { label: 'Founded', value: '1764' },
  { label: 'Population', value: '~6,000' },
  { label: 'Area', value: '56 sq miles' },
  { label: 'Elevation', value: '804 ft' },
];
---

<BaseLayout title="Town History | Town of Littleton, NH" description="Incorporated in 1764, Littleton has grown from a small mill town to the vibrant commercial and cultural hub of northern New Hampshire.">

  <!-- Hero -->
  <section class="bg-light-blue py-12" aria-labelledby="hero-heading">
    <div class="max-w-7xl mx-auto px-8 text-center">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="list-none p-0 m-0 flex items-center justify-center gap-2 text-sm text-body-text">
          <li>
            <a href="/about" class="hover:underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded">
              About
            </a>
          </li>
          <li aria-hidden="true">/</li>
          <li aria-current="page" class="text-navy font-medium">Town History</li>
        </ol>
      </nav>
      <h1 id="hero-heading" class="text-4xl font-bold text-navy mb-4">Town History</h1>
      <p class="text-lg text-body-text max-w-2xl mx-auto">
        Incorporated in 1764, Littleton has grown from a small mill town to the vibrant commercial and cultural hub of northern New Hampshire.
      </p>
    </div>
  </section>

  <!-- Timeline -->
  <section class="py-16 bg-white" aria-labelledby="timeline-heading">
    <div class="max-w-7xl mx-auto px-8">
      <h2 id="timeline-heading" class="text-3xl font-bold text-navy text-center mb-12">Littleton Through the Years</h2>
      <div class="timeline">
        {timelineEvents.map((event) => (
          <div class="timeline-entry">
            <h3 class="timeline-year">{event.year}</h3>
            <p class="text-body-text leading-relaxed">{event.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Historic Landmarks -->
  <section class="py-16 bg-light-blue" aria-labelledby="landmarks-heading">
    <div class="max-w-7xl mx-auto px-8">
      <h2 id="landmarks-heading" class="text-3xl font-bold text-navy text-center mb-8">Historic Landmarks</h2>
      <div class="landmarks-grid">
        {landmarks.map((landmark) => (
          <article class="bg-white rounded-lg p-6 shadow-sm">
            <div class="w-12 h-12 bg-light-blue rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-navy mb-2">{landmark.name}</h3>
            <p class="text-body-text">{landmark.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Quick Facts -->
  <section class="py-16 bg-white" aria-labelledby="facts-heading">
    <div class="max-w-7xl mx-auto px-8 text-center">
      <h2 id="facts-heading" class="text-3xl font-bold text-navy mb-8">Quick Facts</h2>
      <div class="facts-grid">
        {quickFacts.map((fact) => (
          <div class="fact-card">
            <!-- Fixed: p → h3 so WAVE doesn't flag as "possible heading" -->
            <h3 class="text-3xl font-bold text-navy mb-2">{fact.value}</h3>
            <p class="fact-label">{fact.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .timeline {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .timeline-entry {
    border-left: 4px solid #C8973A;
    padding-left: 24px;
    padding-bottom: 32px;
    margin-left: 8px;
  }
  .timeline-entry:last-child {
    padding-bottom: 0;
  }

  .timeline-year {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1B2E4B;
    margin-bottom: 0.5rem;
  }

  .landmarks-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 1200px;
    margin: 40px auto;
    padding: 0 32px;
  }
  @media (max-width: 768px) {
    .landmarks-grid { grid-template-columns: 1fr; }
  }

  .facts-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    max-width: 1000px;
    margin: 40px auto;
    padding: 0 32px;
  }
  @media (max-width: 768px) {
    .facts-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .fact-card {
    background-color: #EEF2F8;
    border-radius: 8px;
    padding: 24px;
    text-align: center;
  }

  .fact-label {
    color: #2C4A7C;
    font-weight: 500;
  }
</style>