---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Police Department | Town of Littleton, NH" description="The Littleton Police Department is committed to protecting and serving our community with professionalism, integrity, and respect.">

  <!-- Emergency Notice -->
  <div role="region" aria-label="Emergency contact information" class="emergency-banner">
    <p>
      <strong>For emergencies call </strong>
      <a href="tel:911" class="emergency-link" aria-label="Call 911 for emergencies">911</a>
    </p>
  </div>

  <!-- Hero -->
  <section aria-labelledby="hero-heading" class="bg-light-blue py-12">
    <div class="max-w-7xl mx-auto px-8">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-sm text-body-text list-none p-0 m-0">
          <li>
            <a href="/departments" class="hover:underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded">
              Departments
            </a>
          </li>
          <li aria-hidden="true">/</li>
          <li aria-current="page" class="text-navy font-medium">Police Department</li>
        </ol>
      </nav>
      <h1 id="hero-heading" class="text-4xl font-bold text-navy mb-4">Police Department</h1>
      <p class="text-lg text-body-text max-w-3xl mb-6">
        The Littleton Police Department is committed to protecting and serving our community with professionalism, integrity, and respect.
      </p>
      <div class="flex flex-col gap-3">
        <div class="flex items-center gap-2">
          <svg aria-hidden="true" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="#DC2626" stroke-width="2">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          <span class="font-bold text-xl" style="color: #DC2626;">EMERGENCY: 911</span>
        </div>
        <div class="flex items-center gap-2">
          <svg aria-hidden="true" class="w-5 h-5 text-mid-blue" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          <span class="text-body-text">Non-Emergency: </span>
          <a href="tel:+16035550104" class="text-navy font-semibold underline hover:no-underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded" aria-label="Call non-emergency line at 603-555-0104">
            (603) 555-0104
          </a>
        </div>
        <div class="flex items-center gap-2">
          <svg aria-hidden="true" class="w-5 h-5 text-mid-blue" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          <a href="mailto:police@littletonnh.gov" class="text-navy font-semibold underline hover:no-underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded">
            police@littletonnh.gov
          </a>
        </div>
        <div class="flex items-center gap-2">
          <svg aria-hidden="true" class="w-5 h-5 text-mid-blue" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
          <span class="text-body-text">24/7 Dispatch Available</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section aria-labelledby="services-heading" class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-8">
      <h2 id="services-heading" class="text-3xl font-bold text-navy text-center mb-8">Department Services</h2>
      <div class="services-grid">

        <article class="service-card">
          <div class="service-icon-wrap">
            <svg aria-hidden="true" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 6v6l4 2"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-navy mb-2">Patrol Services</h3>
          <p class="text-body-text">24/7 patrol coverage throughout Littleton ensuring public safety.</p>
        </article>

        <article class="service-card">
          <div class="service-icon-wrap">
            <svg aria-hidden="true" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
              <circle cx="11" cy="11" r="8"/>
              <line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-navy mb-2">Criminal Investigations</h3>
          <p class="text-body-text">Professional investigation of crimes to bring justice to victims.</p>
        </article>

        <article class="service-card">
          <div class="service-icon-wrap">
            <svg aria-hidden="true" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-navy mb-2">Community Policing</h3>
          <p class="text-body-text">Building relationships through community outreach and engagement programs.</p>
        </article>

        <article class="service-card">
          <div class="service-icon-wrap">
            <svg aria-hidden="true" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
              <path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/>
              <circle cx="7" cy="17" r="2"/>
              <circle cx="17" cy="17" r="2"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-navy mb-2">Traffic Enforcement</h3>
          <p class="text-body-text">Keeping roads safe through speed enforcement and accident response.</p>
        </article>

        <article class="service-card">
          <div class="service-icon-wrap">
            <svg aria-hidden="true" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
              <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
              <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-navy mb-2">School Resource Officer</h3>
          <p class="text-body-text">Dedicated officer serving Littleton schools to ensure student safety.</p>
        </article>

        <article class="service-card">
          <div class="service-icon-wrap">
            <svg aria-hidden="true" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
              <path d="M10 5.172C10 3.782 8.423 2.679 6.5 3c-2.823.47-4.113 6.006-4 7 .08.703 1.725 1.722 3.656 1 1.261-.472 1.96-1.45 2.344-2.5"/>
              <path d="M14.267 5.172c0-1.39 1.577-2.493 3.5-2.172 2.823.47 4.113 6.006 4 7-.08.703-1.725 1.722-3.656 1-1.261-.472-1.855-1.45-2.239-2.5"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-navy mb-2">Animal Control</h3>
          <p class="text-body-text">Responding to animal complaints and enforcing animal control ordinances.</p>
        </article>

      </div>
    </div>
  </section>

  <!-- Community Programs -->
  <section aria-labelledby="programs-heading" class="py-16 bg-light-blue">
    <div class="max-w-7xl mx-auto px-8">
      <h2 id="programs-heading" class="text-3xl font-bold text-navy text-center mb-8">Community Programs</h2>
      <div class="programs-grid">

        <article class="program-card">
          <h3 class="text-xl font-semibold text-navy mb-3">Neighborhood Watch</h3>
          <p class="text-body-text mb-4">Join your neighbors in keeping Littleton safe. Our Neighborhood Watch program provides training and resources for community-based crime prevention.</p>
          <a href="/departments/police/neighborhood-watch" class="program-link" aria-label="Learn more about Neighborhood Watch program">
            Learn More <span aria-hidden="true">→</span>
          </a>
        </article>

        <article class="program-card">
          <h3 class="text-xl font-semibold text-navy mb-3">D.A.R.E Program</h3>
          <p class="text-body-text mb-4">Drug Abuse Resistance Education program taught in Littleton schools, empowering students to make healthy choices and resist negative influences.</p>
          <a href="/departments/police/dare" class="program-link" aria-label="Learn more about D.A.R.E Program">
            Learn More <span aria-hidden="true">→</span>
          </a>
        </article>

        <article class="program-card">
          <h3 class="text-xl font-semibold text-navy mb-3">Citizen Police Academy</h3>
          <p class="text-body-text mb-4">A free 10-week program giving residents an inside look at police operations, including ride-alongs, defensive tactics demonstrations, and more.</p>
          <a href="/departments/police/citizen-academy" class="program-link" aria-label="Learn more about Citizen Police Academy">
            Learn More <span aria-hidden="true">→</span>
          </a>
        </article>

      </div>
    </div>
  </section>

  <!-- Important Numbers -->
  <section aria-labelledby="numbers-heading" class="py-16 bg-navy">
    <div class="max-w-7xl mx-auto px-8">
      <h2 id="numbers-heading" class="text-3xl font-bold text-white text-center mb-8">Important Numbers</h2>
      <div class="numbers-grid">
        <div class="number-card">
          <h3 class="text-base font-semibold text-white mb-2">Emergency</h3>
          <a href="tel:911" class="number-link" aria-label="Call emergency services at 911">911</a>
        </div>
        <div class="number-card">
          <h3 class="text-base font-semibold text-white mb-2">Non-Emergency Dispatch</h3>
          <a href="tel:+16035550104" class="number-link" aria-label="Call non-emergency dispatch at 603-555-0104">(603) 555-0104</a>
        </div>
        <div class="number-card">
          <h3 class="text-base font-semibold text-white mb-2">Detective Division</h3>
          <a href="tel:+16035550109" class="number-link" aria-label="Call detective division at 603-555-0109">(603) 555-0109</a>
        </div>
        <div class="number-card">
          <h3 class="text-base font-semibold text-white mb-2">Records Division</h3>
          <a href="tel:+16035550110" class="number-link" aria-label="Call records division at 603-555-0110">(603) 555-0110</a>
        </div>
        <div class="number-card">
          <h3 class="text-base font-semibold text-white mb-2">Animal Control</h3>
          <a href="tel:+16035550111" class="number-link" aria-label="Call animal control at 603-555-0111">(603) 555-0111</a>
        </div>
        <div class="number-card">
          <h3 class="text-base font-semibold text-white mb-2">Administration</h3>
          <a href="tel:+16035550112" class="number-link" aria-label="Call administration at 603-555-0112">(603) 555-0112</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Hours & Location -->
  <section aria-labelledby="info-heading" class="bg-white">
    <h2 id="info-heading" class="sr-only">Station Hours and Location</h2>
    <div class="info-grid">
      <div>
        <h3 class="text-2xl font-bold text-navy mb-6">Station Hours</h3>
        <dl class="space-y-3">
          <div class="flex justify-between border-b border-light-blue pb-3">
            <dt class="font-semibold text-navy">Dispatch</dt>
            <dd class="text-body-text">24 hours, 7 days a week</dd>
          </div>
          <div class="flex justify-between border-b border-light-blue pb-3">
            <dt class="font-semibold text-navy">Administration</dt>
            <dd class="text-body-text">Mon&ndash;Fri 8:00 AM&ndash;4:00 PM</dd>
          </div>
          <div class="flex justify-between">
            <dt class="font-semibold text-navy">Records</dt>
            <dd class="text-body-text">Mon&ndash;Fri 8:00 AM&ndash;4:00 PM</dd>
          </div>
        </dl>
      </div>
      <div>
        <h3 class="text-2xl font-bold text-navy mb-6">Location</h3>
        <address class="not-italic text-body-text mb-4">
          <p class="font-medium text-navy">Littleton Police Department</p>
          <p>75 Cottage Street</p>
          <p>Littleton, NH 03561</p>
        </address>
        <div
          class="bg-gray-200 h-48 rounded-lg flex items-center justify-center"
          role="img"
          aria-label="Map showing Littleton Police Department location at 75 Cottage Street"
        >
          <span class="text-gray-500" aria-hidden="true">Map Placeholder</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Back to Departments -->
  <section class="py-8 bg-light-blue">
    <div class="max-w-7xl mx-auto px-8 text-center">
      <a
        href="/departments"
        class="inline-flex items-center gap-2 text-navy font-semibold hover:underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded"
      >
        <svg aria-hidden="true" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="19" y1="12" x2="5" y2="12"/>
          <polyline points="12 19 5 12 12 5"/>
        </svg>
        Back to All Departments
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .emergency-banner {
    background-color: #FEF2F2;
    border: 3px solid #DC2626;
    padding: 20px;
    text-align: center;
    font-size: 1.5rem;
    font-weight: 700;
  }

  .emergency-link {
    color: #DC2626;
    text-decoration: underline;
  }
  .emergency-link:focus {
    outline: 2px solid #DC2626;
    outline-offset: 2px;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 1200px;
    margin: 0 auto;
  }
  @media (max-width: 1024px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .services-grid { grid-template-columns: 1fr; }
  }

  .service-card {
    background-color: #EEF2F8;
    padding: 24px;
    border-radius: 8px;
  }

  .service-icon-wrap {
    width: 48px;
    height: 48px;
    background-color: #2C4A7C;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
  }

  .programs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 1200px;
    margin: 0 auto;
  }
  @media (max-width: 768px) {
    .programs-grid { grid-template-columns: 1fr; }
  }

  .program-card {
    background-color: white;
    padding: 24px;
    border-radius: 8px;
    border-top: 4px solid #2C4A7C;
  }

  /* Fixed: navy on white passes 4.5:1 — was text-gold on white which failed */
  .program-link {
    color: #1B2E4B;
    font-weight: 600;
    text-decoration: underline;
  }
  .program-link:hover { color: #2C4A7C; }
  .program-link:focus {
    outline: 2px solid #1B2E4B;
    outline-offset: 2px;
    border-radius: 2px;
  }

  .numbers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    max-width: 1200px;
    margin: 0 auto;
  }
  @media (max-width: 768px) {
    .numbers-grid { grid-template-columns: 1fr; }
  }

  .number-card {
    background-color: rgba(255, 255, 255, 0.1);
    padding: 24px;
    border-radius: 8px;
    text-align: center;
  }

  /* Gold on navy — passes contrast fine, left unchanged */
  .number-link {
    font-size: 1.5rem;
    font-weight: 700;
    color: #C8973A;
    text-decoration: none;
  }
  .number-link:hover { text-decoration: underline; }
  .number-link:focus {
    outline: 2px solid #C8973A;
    outline-offset: 2px;
    border-radius: 2px;
  }

  .info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 48px 20px;
  }
  @media (max-width: 768px) {
    .info-grid { grid-template-columns: 1fr; }
  }
</style>