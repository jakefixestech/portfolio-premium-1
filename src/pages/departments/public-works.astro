---
import BaseLayout from '../../layouts/BaseLayout.astro';

const services = [
  {
    title: 'Road Maintenance',
    description: 'Pothole repairs, road resurfacing, and pavement marking throughout town.',
    slug: 'road-maintenance',
  },
  {
    title: 'Snow & Ice Control',
    description: 'Winter road treatment, plowing, and sanding to keep roads safe.',
    slug: 'snow-ice-control',
  },
  {
    title: 'Water & Sewer',
    description: 'Operation and maintenance of the town\'s water distribution and sewer systems.',
    slug: 'water-sewer',
  },
  {
    title: 'Stormwater Management',
    description: 'Maintaining drainage systems and culverts to prevent flooding.',
    slug: 'stormwater-management',
  },
  {
    title: 'Parks & Grounds',
    description: 'Maintenance of town parks, athletic fields, and public green spaces.',
    slug: 'parks-grounds',
  },
  {
    title: 'Solid Waste',
    description: 'Coordinating trash collection and recycling services for residents.',
    slug: 'solid-waste',
  },
];

const commonIssues = [
  'Pothole',
  'Broken streetlight',
  'Fallen tree',
  'Water main break',
  'Drainage issue',
];

const currentProjects = [
  { name: 'Main Street Repaving', status: 'In Progress', statusClass: 'status-progress' },
  { name: 'Route 116 Culvert Replacement', status: 'Planned', statusClass: 'status-planned' },
  { name: 'Water Main Upgrade, Elm Street', status: 'Completed', statusClass: 'status-completed' },
];
---

<BaseLayout title="Public Works | Town of Littleton, NH" description="The Public Works Department maintains Littleton's roads, bridges, water systems, and public facilities.">

  <section class="bg-light-blue py-12" aria-labelledby="hero-heading">
    <div class="max-w-7xl mx-auto px-8">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-sm text-body-text">
          <li>
            <a href="/departments" class="underline hover:no-underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded">
              Departments
            </a>
          </li>
          <li aria-hidden="true">/</li>
          <li aria-current="page" class="text-navy font-medium">Public Works</li>
        </ol>
      </nav>
      <h1 id="hero-heading" class="text-4xl font-bold text-navy mb-4">Public Works</h1>
      <p class="text-lg text-body-text max-w-3xl mb-6">
        The Public Works Department maintains Littleton's roads, bridges, water systems, and public facilities to keep our community safe and running smoothly.
      </p>
      <div class="flex flex-wrap gap-6 text-body-text">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          <a href="tel:+16035550102" class="underline hover:no-underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded">
            (603) 555-0102
          </a>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          <a href="mailto:publicworks@littletonnh.gov" class="underline hover:no-underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded">
            publicworks@littletonnh.gov
          </a>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span>Mon&ndash;Fri 7:00 AM&ndash;3:30 PM</span>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-16" aria-labelledby="services-heading">
    <div class="max-w-7xl mx-auto px-8">
      <h2 id="services-heading" class="text-3xl font-bold text-navy text-center mb-12">Our Services</h2>
      <div class="services-grid">
        {services.map((service) => (
          <article class="service-card">
            <div class="w-12 h-12 bg-light-blue rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-navy mb-2">{service.title}</h3>
            <p class="text-body-text mb-4">{service.description}</p>
            <a
              href={`/departments/public-works/${service.slug}`}
              class="service-link"
              aria-label={`Learn more about ${service.title}`}
            >
              Learn More <span aria-hidden="true">→</span>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-light-blue py-16" aria-labelledby="report-section-heading">
    <h2 id="report-section-heading" class="sr-only">Report a Problem and Current Projects</h2>
    <div class="report-grid">
      <div>
        <h3 class="text-2xl font-bold text-navy mb-4">Report a Problem</h3>
        <p class="text-body-text mb-6">
          Help us keep Littleton safe and well-maintained by reporting issues you encounter. Our team responds promptly and prioritizes based on safety concerns.
        </p>
        <h4 class="text-lg font-semibold text-navy mb-3">Common Issues</h4>
        <ul class="space-y-2 mb-6">
          {commonIssues.map((issue) => (
            <li class="flex items-center gap-2 text-body-text">
              <svg class="w-4 h-4 text-mid-blue flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
              {issue}
            </li>
          ))}
        </ul>
        <a
          href="/services/report"
          class="inline-block bg-navy text-white px-6 py-3 rounded-lg font-semibold hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2"
          aria-label="Submit a problem report to Public Works"
        >
          Submit a Report <span aria-hidden="true">→</span>
        </a>
      </div>
      <div>
        <h3 class="text-2xl font-bold text-navy mb-4">Current Projects</h3>
        <ul class="space-y-4">
          {currentProjects.map((project) => (
            <li class="bg-white p-4 rounded-lg flex items-center justify-between">
              <span class="text-navy font-medium">{project.name}</span>
              <span class={`status-badge ${project.statusClass}`}>
                {project.status}
              </span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-navy py-16" aria-labelledby="winter-heading">
    <div class="max-w-7xl mx-auto px-8">
      <h2 id="winter-heading" class="text-3xl font-bold text-white text-center mb-10">Winter Services</h2>
      <div class="winter-grid">
        <div class="winter-card">
          <h3 class="text-xl font-semibold text-white mb-3">Snow Routes</h3>
          <p class="winter-text">
            Priority roads are treated first. View the snow route map to see when your street will be plowed.
          </p>
        </div>
        <div class="winter-card">
          <h3 class="text-xl font-semibold text-white mb-3">Salt &amp; Sand</h3>
          <p class="winter-text">
            We use a salt/sand mix to treat roads during winter storms for optimal traction and ice melt.
          </p>
        </div>
        <div class="winter-card">
          <h3 class="text-xl font-semibold text-white mb-3">Report Issues</h3>
          <p class="winter-text">
            Roads still icy? Call us at
            <a href="tel:+16035550102" class="underline hover:no-underline focus:outline-none focus:ring-2 focus:ring-gold rounded winter-link">
              (603) 555-0102
            </a>
            to report conditions.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white" aria-labelledby="info-heading">
    <h2 id="info-heading" class="sr-only">Hours and Location</h2>
    <div class="info-grid">
      <div>
        <h3 class="text-2xl font-bold text-navy mb-6">Office Hours</h3>
        <dl class="space-y-3">
          <div class="flex justify-between">
            <dt class="text-body-text">Monday</dt>
            <dd class="text-navy font-medium">7:00 AM &ndash; 3:30 PM</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-body-text">Tuesday</dt>
            <dd class="text-navy font-medium">7:00 AM &ndash; 3:30 PM</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-body-text">Wednesday</dt>
            <dd class="text-navy font-medium">7:00 AM &ndash; 3:30 PM</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-body-text">Thursday</dt>
            <dd class="text-navy font-medium">7:00 AM &ndash; 3:30 PM</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-body-text">Friday</dt>
            <dd class="text-navy font-medium">7:00 AM &ndash; 3:30 PM</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-body-text">Saturday</dt>
            <dd class="text-navy font-medium">Closed</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-body-text">Sunday</dt>
            <dd class="text-navy font-medium">Closed</dd>
          </div>
        </dl>
        <p class="mt-4 text-sm text-body-text">
          <strong>Note:</strong> 24/7 emergency line available for water and sewer emergencies.
        </p>
      </div>
      <div>
        <h3 class="text-2xl font-bold text-navy mb-6">Location</h3>
        <address class="not-italic text-body-text mb-4">
          <p class="font-medium text-navy">Public Works Facility</p>
          <p>200 Industrial Park Road</p>
          <p>Littleton, NH 03561</p>
        </address>
        <div
          class="map-placeholder h-48 rounded-lg flex items-center justify-center"
          role="img"
          aria-label="Map showing Public Works facility location at 200 Industrial Park Road"
        >
          <span class="map-placeholder-text text-sm" aria-hidden="true">Map Placeholder</span>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-light-blue py-8">
    <div class="max-w-7xl mx-auto px-8 text-center">
      <a
        href="/departments"
        class="inline-flex items-center gap-2 text-navy font-semibold underline hover:no-underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Back to All Departments
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 1200px;
    margin: 0 auto;
  }
  @media (max-width: 900px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .services-grid { grid-template-columns: 1fr; }
  }

  .service-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-top: 4px solid #2C4A7C;
    border-radius: 8px;
    padding: 24px;
  }

  .service-link {
    color: #1B2E4B;
    font-weight: 600;
    text-decoration: underline;
  }
  .service-link:hover {
    text-decoration: none;
    color: #2C4A7C;
  }
  .service-link:focus {
    outline: 2px solid #1B2E4B;
    outline-offset: 2px;
    border-radius: 2px;
  }

  .report-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px;
  }
  @media (max-width: 768px) {
    .report-grid { grid-template-columns: 1fr; }
  }

  .winter-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 1200px;
    margin: 0 auto;
  }
  @media (max-width: 768px) {
    .winter-grid { grid-template-columns: 1fr; }
  }

  .winter-card {
    background-color: rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 24px;
  }

  .winter-text {
    color: #ffffff;
  }

  .winter-link {
    color: #C8973A;
  }

  .info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 48px 32px;
  }
  @media (max-width: 768px) {
    .info-grid { grid-template-columns: 1fr; }
  }

  .map-placeholder {
    background-color: #e5e7eb;
  }

  .map-placeholder-text {
    color: #374151;
  }

  .status-badge {
    padding: 4px 12px;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .status-progress {
    background-color: #C8973A;
    color: white;
  }

  .status-planned {
    background-color: #2C4A7C;
    color: white;
  }

  .status-completed {
    background-color: #1B2E4B;
    color: white;
  }
</style>