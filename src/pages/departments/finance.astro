---
import BaseLayout from '../../layouts/BaseLayout.astro';

const services = [
  { title: 'Property Tax Collection', description: 'Billing and collection of annual property taxes for all Littleton parcels.' },
  { title: 'Budget Management', description: 'Preparation and oversight of the annual municipal operating and capital budgets.' },
  { title: 'Financial Reporting', description: 'Monthly and annual financial statements and audit coordination.' },
  { title: 'Accounts Payable', description: 'Processing vendor payments and managing town expenditures.' },
  { title: 'Payroll', description: 'Processing payroll for all town employees and managing benefits administration.' },
  { title: 'Grants Management', description: 'Identifying and administering state and federal grant opportunities.' },
];

const documents = [
  { title: 'FY2025 Annual Budget', size: '2.4 MB' },
  { title: 'FY2024 Audit Report', size: '1.8 MB' },
  { title: 'FY2024 Annual Report', size: '3.2 MB' },
  { title: 'FY2023 Audit Report', size: '1.7 MB' },
  { title: 'FY2023 Annual Budget', size: '2.1 MB' },
  { title: 'Tax Rate History (2020–2025)', size: '0.5 MB' },
];
---

<BaseLayout title="Finance Department | Town of Littleton, NH" description="The Finance Department manages the town's budget, financial reporting, tax collection, and ensures responsible stewardship of public funds.">

  <!-- Hero -->
  <section class="bg-light-blue py-12" aria-labelledby="hero-heading">
    <div class="max-w-7xl mx-auto px-8">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-sm text-body-text list-none p-0 m-0">
          <li>
            <a href="/departments" class="hover:underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded">
              Departments
            </a>
          </li>
          <li aria-hidden="true">/</li>
          <li aria-current="page" class="text-navy font-semibold">Finance</li>
        </ol>
      </nav>
      <!-- Fixed: h2 → h1 -->
      <h1 id="hero-heading" class="text-4xl font-bold text-navy mb-4">Finance Department</h1>
      <p class="text-lg text-body-text max-w-3xl mb-6">
        The Finance Department manages the town's budget, financial reporting, tax collection, and ensures responsible stewardship of public funds.
      </p>
      <div class="flex flex-wrap gap-6 text-body-text">
        <a href="tel:+16035550106" class="flex items-center gap-2 underline hover:no-underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded" aria-label="Call Finance Department at 603-555-0106">
          <svg class="w-5 h-5 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          (603) 555-0106
        </a>
        <a href="mailto:finance@littletonnh.gov" class="flex items-center gap-2 underline hover:no-underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded" aria-label="Email Finance Department">
          <svg class="w-5 h-5 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          finance@littletonnh.gov
        </a>
        <span class="flex items-center gap-2">
          <svg class="w-5 h-5 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          Mon&ndash;Fri 8:00 AM&ndash;4:30 PM
        </span>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-16 bg-white" aria-labelledby="services-heading">
    <div class="max-w-7xl mx-auto px-8">
      <h2 id="services-heading" class="text-3xl font-bold text-navy mb-8 text-center">Our Services</h2>
      <div class="services-grid">
        {services.map((service) => (
          <article class="bg-light-blue p-6 rounded-lg">
            <h3 class="text-xl font-semibold text-navy mb-3">{service.title}</h3>
            <p class="text-body-text">{service.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Pay Your Taxes -->
  <section class="py-16 bg-navy" aria-labelledby="pay-heading">
    <div class="max-w-7xl mx-auto px-8">
      <h2 id="pay-heading" class="text-3xl font-bold text-white mb-8 text-center">Pay Your Property Taxes</h2>
      <div class="pay-grid">

        <div>
          <h3 class="text-xl font-semibold text-gold mb-6">Payment Options</h3>
          <ul class="space-y-4 text-white list-none p-0 m-0">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-gold mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <div>
                <strong>Online (Recommended)</strong>
                <p class="text-white text-sm mt-1">Pay securely with credit card or e-check</p>
                <a
                  href="/services/pay"
                  class="inline-block mt-2 px-4 py-2 bg-gold text-navy font-semibold rounded hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-gold focus:ring-offset-2"
                  aria-label="Pay property taxes online"
                >
                  Pay Online <span aria-hidden="true">→</span>
                </a>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-gold mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <div>
                <strong>By Mail</strong>
                <p class="text-white text-sm mt-1">Mail checks payable to "Town of Littleton" to:<br/>125 Main Street, Littleton, NH 03561</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-gold mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
              </svg>
              <div>
                <strong>In Person</strong>
                <p class="text-white text-sm mt-1">Visit Town Hall during business hours<br/>Monday&ndash;Friday, 8:00 AM&ndash;4:30 PM</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-gold mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/>
              </svg>
              <div>
                <strong>Drop Box</strong>
                <p class="text-white text-sm mt-1">24/7 secure drop box located at the Town Hall entrance</p>
              </div>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-xl font-semibold text-gold mb-6">Due Dates</h3>
          <div class="due-dates-card">
            <table class="w-full text-white">
              <caption class="sr-only">Property tax due dates for the Town of Littleton</caption>
              <thead>
                <tr class="border-b border-white-20">
                  <th scope="col" class="text-left py-3 font-semibold">Tax Issue</th>
                  <th scope="col" class="text-left py-3 font-semibold">Due Date</th>
                </tr>
              </thead>
              <tbody>
                <tr class="border-b border-white-10">
                  <td class="py-3">First Issue</td>
                  <td class="py-3">July 1</td>
                </tr>
                <tr>
                  <td class="py-3">Second Issue</td>
                  <td class="py-3">December 1</td>
                </tr>
              </tbody>
            </table>
            <p class="text-white text-sm mt-4">
              <!-- Fixed: text-gold → text-white for contrast on navy background -->
              <strong class="text-white">Note:</strong> Interest of 8% per annum accrues on all late payments beginning the day after the due date.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Budget Documents -->
  <section class="py-16 bg-light-blue" aria-labelledby="docs-heading">
    <div class="max-w-7xl mx-auto px-8">
      <h2 id="docs-heading" class="text-3xl font-bold text-navy mb-8 text-center">Budget &amp; Financial Documents</h2>
      <div class="docs-grid">
        {documents.map((doc) => (
          <div class="bg-white p-6 rounded-lg doc-card">
            <div class="flex items-start gap-4">
              <svg class="w-10 h-10 text-mid-blue flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
              </svg>
              <div>
                <h3 class="text-lg font-semibold text-navy mb-1">{doc.title}</h3>
                <p class="text-sm text-body-text mb-3">PDF &bull; {doc.size}</p>
                <a
                  href="#"
                  class="text-navy font-semibold underline hover:no-underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded"
                  aria-label={`Download ${doc.title} PDF`}
                >
                  Download PDF <span aria-hidden="true">→</span>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Hours & Location -->
  <section class="py-16 bg-white" aria-labelledby="info-heading">
    <h2 id="info-heading" class="sr-only">Office Hours and Location</h2>
    <div class="info-grid">
      <div>
        <h3 class="text-2xl font-bold text-navy mb-6">Office Hours</h3>
        <dl class="space-y-3 text-body-text">
          <div class="flex justify-between">
            <dt>Monday</dt>
            <dd>8:00 AM &ndash; 4:30 PM</dd>
          </div>
          <div class="flex justify-between">
            <dt>Tuesday</dt>
            <dd>8:00 AM &ndash; 4:30 PM</dd>
          </div>
          <div class="flex justify-between">
            <dt>Wednesday</dt>
            <dd>8:00 AM &ndash; 4:30 PM</dd>
          </div>
          <div class="flex justify-between">
            <dt>Thursday</dt>
            <dd>8:00 AM &ndash; 4:30 PM</dd>
          </div>
          <div class="flex justify-between">
            <dt>Friday</dt>
            <dd>8:00 AM &ndash; 4:30 PM</dd>
          </div>
          <div class="flex justify-between">
            <dt>Saturday</dt>
            <dd>Closed</dd>
          </div>
          <div class="flex justify-between">
            <dt>Sunday</dt>
            <dd>Closed</dd>
          </div>
        </dl>
      </div>
      <div>
        <h3 class="text-2xl font-bold text-navy mb-6">Location</h3>
        <address class="not-italic text-body-text mb-4">
          <p class="font-semibold text-navy">Littleton Town Hall</p>
          <p>125 Main Street</p>
          <p>Littleton, NH 03561</p>
        </address>
        <div
          class="bg-gray-200 h-48 rounded-lg flex items-center justify-center"
          role="img"
          aria-label="Map showing Finance Department location at 125 Main Street, Littleton NH"
        >
          <span class="text-gray-700" aria-hidden="true">Map Placeholder</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Back to Departments -->
  <section class="py-8 bg-light-blue">
    <div class="max-w-7xl mx-auto px-8 text-center">
      <a
        href="/departments"
        class="inline-flex items-center gap-2 text-navy font-semibold hover:underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Back to All Departments
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  @media (max-width: 1024px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .services-grid { grid-template-columns: 1fr; }
  }

  .pay-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    max-width: 1200px;
    margin: 40px auto;
    padding: 0 32px;
  }
  @media (max-width: 768px) {
    .pay-grid { grid-template-columns: 1fr; }
  }

  .due-dates-card {
    background-color: rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 24px;
  }

  .border-white-20 {
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
  }

  .border-white-10 {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .docs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    max-width: 1200px;
    margin: 40px auto;
    padding: 0 32px;
  }
  @media (max-width: 768px) {
    .docs-grid { grid-template-columns: 1fr; }
  }

  .doc-card {
    border-left: 4px solid #C8973A;
  }

  .info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 48px 20px;
  }
  @media (max-width: 768px) {
    .info-grid { grid-template-columns: 1fr; }
  }
</style>