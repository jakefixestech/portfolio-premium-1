---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Town Clerk | Town of Littleton, NH" description="The Town Clerk's office maintains official town records, manages elections, and provides a wide range of resident services.">

  <!-- Page Hero -->
  <section aria-labelledby="hero-heading" class="bg-light-blue py-12">
    <div class="max-w-7xl mx-auto px-8">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-sm text-body-text">
          <li><a href="/departments" class="hover:underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded">Departments</a></li>
          <li aria-hidden="true">/</li>
          <li aria-current="page" class="font-semibold">Town Clerk</li>
        </ol>
      </nav>
      <h1 id="hero-heading" class="text-4xl font-bold text-navy mb-4">Town Clerk</h1>
      <p class="text-lg text-body-text mb-6 max-w-3xl">
        The Town Clerk's office maintains official town records, manages elections, and provides a wide range of resident services.
      </p>
      <div class="flex flex-wrap items-center gap-6 text-body-text">
        <span class="flex items-center gap-2">
          <svg aria-hidden="true" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          <a href="tel:+16035550101" class="hover:underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded">
            (603) 555-0101
          </a>
        </span>
        <span aria-hidden="true" class="hidden sm:inline">|</span>
        <span class="flex items-center gap-2">
          <svg aria-hidden="true" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          <a href="mailto:clerk@littletonnh.gov" class="hover:underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded">
            clerk@littletonnh.gov
          </a>
        </span>
        <span aria-hidden="true" class="hidden sm:inline">|</span>
        <span class="flex items-center gap-2">
          <svg aria-hidden="true" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          Mon&ndash;Fri 8:00 AM&ndash;4:00 PM
        </span>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section aria-labelledby="services-heading" class="bg-white py-12">
    <div class="max-w-7xl mx-auto px-8">
      <h2 id="services-heading" class="text-3xl font-bold text-navy text-center mb-2">Our Services</h2>
    </div>
    <div class="services-grid">

      <article class="bg-white border-t-4 border-mid-blue p-6 shadow-sm">
        <svg aria-hidden="true" class="w-10 h-10 text-mid-blue mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        <h3 class="text-xl font-semibold text-navy mb-2">Vital Records</h3>
        <p class="text-body-text mb-4">Birth, death, and marriage certificates for events recorded in Littleton.</p>
        <a href="/departments/town-clerk/vital-records" class="service-link" aria-label="Learn more about Vital Records">
          Learn More <span aria-hidden="true">→</span>
        </a>
      </article>

      <article class="bg-white border-t-4 border-mid-blue p-6 shadow-sm">
        <svg aria-hidden="true" class="w-10 h-10 text-mid-blue mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
        </svg>
        <h3 class="text-xl font-semibold text-navy mb-2">Voter Registration</h3>
        <p class="text-body-text mb-4">Register to vote or update your registration information.</p>
        <a href="/services/voting" class="service-link" aria-label="Learn more about Voter Registration">
          Learn More <span aria-hidden="true">→</span>
        </a>
      </article>

      <article class="bg-white border-t-4 border-mid-blue p-6 shadow-sm">
        <svg aria-hidden="true" class="w-10 h-10 text-mid-blue mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5"/>
        </svg>
        <h3 class="text-xl font-semibold text-navy mb-2">Dog Licensing</h3>
        <p class="text-body-text mb-4">Annual dog licenses are required for all dogs over 4 months old.</p>
        <a href="/departments/town-clerk/dog-licensing" class="service-link" aria-label="Learn more about Dog Licensing">
          Learn More <span aria-hidden="true">→</span>
        </a>
      </article>

      <article class="bg-white border-t-4 border-mid-blue p-6 shadow-sm">
        <svg aria-hidden="true" class="w-10 h-10 text-mid-blue mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
        </svg>
        <h3 class="text-xl font-semibold text-navy mb-2">Marriage Licenses</h3>
        <p class="text-body-text mb-4">Apply for a marriage license at least 5 days before your ceremony.</p>
        <a href="/departments/town-clerk/marriage-licenses" class="service-link" aria-label="Learn more about Marriage Licenses">
          Learn More <span aria-hidden="true">→</span>
        </a>
      </article>

      <article class="bg-white border-t-4 border-mid-blue p-6 shadow-sm">
        <svg aria-hidden="true" class="w-10 h-10 text-mid-blue mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
        </svg>
        <h3 class="text-xl font-semibold text-navy mb-2">Business Certificates</h3>
        <p class="text-body-text mb-4">Register a trade name or DBA for your Littleton business.</p>
        <a href="/departments/town-clerk/business-certificates" class="service-link" aria-label="Learn more about Business Certificates">
          Learn More <span aria-hidden="true">→</span>
        </a>
      </article>

      <article class="bg-white border-t-4 border-mid-blue p-6 shadow-sm">
        <svg aria-hidden="true" class="w-10 h-10 text-mid-blue mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <h3 class="text-xl font-semibold text-navy mb-2">Public Records Requests</h3>
        <p class="text-body-text mb-4">Request access to public records under RSA 91-A.</p>
        <a href="/services/public-records" class="service-link" aria-label="Learn more about Public Records Requests">
          Learn More <span aria-hidden="true">→</span>
        </a>
      </article>

    </div>
  </section>

  <!-- Fees Table -->
  <section aria-labelledby="fees-heading" class="bg-light-blue py-12">
    <div class="max-w-3xl mx-auto px-5">
      <h2 id="fees-heading" class="text-3xl font-bold text-navy text-center mb-8">Common Fees</h2>
      <div class="bg-white rounded-lg shadow-sm overflow-hidden">
        <table class="w-full">
          <caption class="sr-only">Town Clerk service fees</caption>
          <thead class="bg-navy text-white">
            <tr>
              <th scope="col" class="text-left px-6 py-4 font-semibold">Service</th>
              <th scope="col" class="text-right px-6 py-4 font-semibold">Fee</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <tr>
              <td class="px-6 py-4 text-body-text">Dog License (Neutered/Spayed)</td>
              <td class="px-6 py-4 text-right text-body-text">$6.50</td>
            </tr>
            <tr>
              <td class="px-6 py-4 text-body-text">Dog License (Intact)</td>
              <td class="px-6 py-4 text-right text-body-text">$9.00</td>
            </tr>
            <tr>
              <td class="px-6 py-4 text-body-text">Marriage License</td>
              <td class="px-6 py-4 text-right text-body-text">$50.00</td>
            </tr>
            <tr>
              <td class="px-6 py-4 text-body-text">Vital Record Copy</td>
              <td class="px-6 py-4 text-right text-body-text">$15.00</td>
            </tr>
            <tr>
              <td class="px-6 py-4 text-body-text">Business Certificate</td>
              <td class="px-6 py-4 text-right text-body-text">$25.00</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Hours & Location -->
  <section aria-labelledby="info-heading" class="bg-white py-12">
    <h2 id="info-heading" class="sr-only">Office Information</h2>
    <div class="info-grid">
      <div>
        <h3 class="text-2xl font-bold text-navy mb-6">Office Hours</h3>
        <dl class="space-y-3 text-body-text">
          <div class="flex justify-between">
            <dt>Monday</dt>
            <dd>8:00 AM &ndash; 4:00 PM</dd>
          </div>
          <div class="flex justify-between">
            <dt>Tuesday</dt>
            <dd>8:00 AM &ndash; 4:00 PM</dd>
          </div>
          <div class="flex justify-between">
            <dt>Wednesday</dt>
            <dd>8:00 AM &ndash; 4:00 PM</dd>
          </div>
          <div class="flex justify-between">
            <dt>Thursday</dt>
            <dd>8:00 AM &ndash; 4:00 PM</dd>
          </div>
          <div class="flex justify-between">
            <dt>Friday</dt>
            <dd>8:00 AM &ndash; 4:00 PM</dd>
          </div>
          <div class="flex justify-between">
            <dt>Saturday</dt>
            <dd>Closed</dd>
          </div>
          <div class="flex justify-between">
            <dt>Sunday</dt>
            <dd>Closed</dd>
          </div>
        </dl>
      </div>
      <div>
        <h3 class="text-2xl font-bold text-navy mb-6">Location</h3>
        <address class="not-italic text-body-text mb-6">
          <p>Littleton Town Hall</p>
          <p>125 Main Street</p>
          <p>Littleton, NH 03561</p>
        </address>
        <div
          role="img"
          aria-label="Map showing Town Clerk office location at 125 Main Street, Littleton NH"
          class="bg-mid-blue/20 h-48 rounded-lg flex items-center justify-center"
        >
          <span class="text-mid-blue font-medium" aria-hidden="true">Map Placeholder</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Back to Departments -->
  <section class="bg-light-blue py-8">
    <div class="max-w-7xl mx-auto px-8 text-center">
      <a
        href="/departments"
        class="inline-flex items-center gap-2 text-navy font-semibold hover:underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded"
      >
        <svg aria-hidden="true" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        Back to All Departments
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 1200px;
    margin: 48px auto;
    padding: 0 20px;
  }
  @media (max-width: 900px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .services-grid { grid-template-columns: 1fr; }
  }

  /* Fixed: navy on white passes 4.5:1 contrast — was text-gold which failed */
  .service-link {
    color: #1B2E4B;
    font-weight: 600;
    text-decoration: underline;
  }
  .service-link:hover {
    color: #2C4A7C;
  }
  .service-link:focus {
    outline: 2px solid #1B2E4B;
    outline-offset: 2px;
    border-radius: 2px;
  }

  .info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 48px 20px;
  }
  @media (max-width: 768px) {
    .info-grid { grid-template-columns: 1fr; }
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>