---
import BaseLayout from '../../layouts/BaseLayout.astro';

const services = [
  {
    title: 'Zoning Permits',
    slug: 'zoning-permits',
    description: 'Apply for zoning permits for new construction, additions, and land use changes.',
    icon: 'clipboard',
  },
  {
    title: 'Variance Requests',
    slug: 'variance-requests',
    description: 'Request relief from zoning requirements when strict application causes hardship.',
    icon: 'scale',
  },
  {
    title: 'Site Plan Review',
    slug: 'site-plan-review',
    description: 'Required for commercial and multi-family development proposals.',
    icon: 'building',
  },
  {
    title: 'Subdivision Review',
    slug: 'subdivision-review',
    description: 'Approval process for dividing land into two or more lots.',
    icon: 'grid',
  },
  {
    title: 'Master Plan',
    slug: 'master-plan',
    description: "Littleton's long-range planning document guiding future growth and development.",
    icon: 'map',
  },
  {
    title: 'Zoning Ordinance',
    slug: 'zoning-ordinance',
    description: 'Access the current zoning ordinance, maps, and district regulations.',
    icon: 'book',
  },
];

const steps = [
  {
    number: 1,
    title: 'Submit Application',
    description: 'Complete and submit your application with required documents and fees.',
  },
  {
    number: 2,
    title: 'Staff Review',
    description: 'Planning staff reviews for completeness and compliance.',
  },
  {
    number: 3,
    title: 'Board Hearing',
    description: 'Present your application at a public hearing if required.',
  },
  {
    number: 4,
    title: 'Decision',
    description: 'Receive written decision within the required timeframe.',
  },
];
---

<BaseLayout title="Planning & Zoning | Town of Littleton, NH" description="The Planning & Zoning Department guides responsible growth and development in Littleton through thoughtful land use planning and zoning administration.">

  <!-- Hero -->
  <section class="bg-light-blue py-12" aria-labelledby="hero-heading">
    <div class="max-w-7xl mx-auto px-8">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-sm text-body-text">
          <li>
            <a href="/departments" class="hover:underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded">
              Departments
            </a>
          </li>
          <li aria-hidden="true">/</li>
          <li aria-current="page" class="text-navy font-medium">Planning &amp; Zoning</li>
        </ol>
      </nav>
      <h1 id="hero-heading" class="text-4xl font-bold text-navy mb-4">Planning &amp; Zoning</h1>
      <p class="text-lg text-body-text max-w-3xl mb-6">
        The Planning &amp; Zoning Department guides responsible growth and development in Littleton through thoughtful land use planning and zoning administration.
      </p>
      <div class="flex flex-wrap gap-6 text-body-text">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          <a href="tel:+16035550103" class="hover:underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded">
            (603) 555-0103
          </a>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          <a href="mailto:planning@littletonnh.gov" class="hover:underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded">
            planning@littletonnh.gov
          </a>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span>Mon&ndash;Fri 8:00 AM&ndash;4:30 PM</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-12 bg-white" aria-labelledby="services-heading">
    <div class="max-w-7xl mx-auto px-8">
      <h2 id="services-heading" class="text-3xl font-bold text-navy text-center mb-8">Our Services</h2>
      <div class="services-grid">
        {services.map((service) => (
          <article class="service-card">
            <div class="w-12 h-12 bg-light-blue rounded-lg flex items-center justify-center mb-4">
              {service.icon === 'clipboard' && (
                <svg class="w-6 h-6 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
                </svg>
              )}
              {service.icon === 'scale' && (
                <svg class="w-6 h-6 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/>
                </svg>
              )}
              {service.icon === 'building' && (
                <svg class="w-6 h-6 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                </svg>
              )}
              {service.icon === 'grid' && (
                <svg class="w-6 h-6 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
                </svg>
              )}
              {service.icon === 'map' && (
                <svg class="w-6 h-6 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
                </svg>
              )}
              {service.icon === 'book' && (
                <svg class="w-6 h-6 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                </svg>
              )}
            </div>
            <h3 class="text-xl font-semibold text-navy mb-2">{service.title}</h3>
            <p class="text-body-text mb-4">{service.description}</p>
            <a
              href={`/departments/planning-zoning/${service.slug}`}
              class="service-link"
              aria-label={`Learn more about ${service.title}`}
            >
              Learn More <span aria-hidden="true">→</span>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Application Process -->
  <section class="py-12 bg-light-blue" aria-labelledby="process-heading">
    <div class="max-w-7xl mx-auto px-8">
      <h2 id="process-heading" class="text-3xl font-bold text-navy text-center mb-8">Application Process</h2>
      <div class="steps-grid">
        {steps.map((step) => (
          <div class="bg-white rounded-lg p-6 text-center shadow-sm">
            <!-- Fixed: was text-gold on white (fails) — now navy on white (passes) -->
            <span class="text-5xl font-bold text-navy mb-4 block" aria-hidden="true">{step.number}</span>
            <h3 class="text-xl font-semibold text-navy mb-2">{step.title}</h3>
            <p class="text-body-text">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Meeting Schedule -->
  <section class="py-12 bg-white" aria-labelledby="meetings-heading">
    <div class="max-w-7xl mx-auto px-8">
      <h2 id="meetings-heading" class="text-3xl font-bold text-navy text-center mb-8">Board Meeting Schedule</h2>
      <div class="meetings-grid">
        <div class="bg-light-blue rounded-lg p-6">
          <h3 class="text-xl font-semibold text-navy mb-4">Planning Board</h3>
          <dl class="space-y-3 text-body-text">
            <div class="flex gap-2">
              <dt class="font-medium">Meets:</dt>
              <dd>Second Thursday of each month</dd>
            </div>
            <div class="flex gap-2">
              <dt class="font-medium">Time:</dt>
              <dd>7:00 PM</dd>
            </div>
            <div class="flex gap-2">
              <dt class="font-medium">Location:</dt>
              <dd>Town Hall, Meeting Room A</dd>
            </div>
          </dl>
          <a
            href="/government/meeting-minutes"
            class="meeting-link"
            aria-label="View Planning Board agendas and minutes"
          >
            View Agendas <span aria-hidden="true">→</span>
          </a>
        </div>
        <div class="bg-light-blue rounded-lg p-6">
          <h3 class="text-xl font-semibold text-navy mb-4">Zoning Board of Adjustment</h3>
          <dl class="space-y-3 text-body-text">
            <div class="flex gap-2">
              <dt class="font-medium">Meets:</dt>
              <dd>Third Wednesday of each month</dd>
            </div>
            <div class="flex gap-2">
              <dt class="font-medium">Time:</dt>
              <dd>7:00 PM</dd>
            </div>
            <div class="flex gap-2">
              <dt class="font-medium">Location:</dt>
              <dd>Town Hall, Meeting Room A</dd>
            </div>
          </dl>
          <a
            href="/government/meeting-minutes"
            class="meeting-link"
            aria-label="View Zoning Board of Adjustment agendas and minutes"
          >
            View Agendas <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Hours & Location -->
  <section class="bg-white" aria-labelledby="info-heading">
    <h2 id="info-heading" class="sr-only">Office Hours and Location</h2>
    <div class="info-grid">
      <div>
        <h3 class="text-2xl font-bold text-navy mb-6">Office Hours</h3>
        <dl class="space-y-2 text-body-text">
          <div class="flex justify-between">
            <dt>Monday</dt>
            <dd>8:00 AM &ndash; 4:30 PM</dd>
          </div>
          <div class="flex justify-between">
            <dt>Tuesday</dt>
            <dd>8:00 AM &ndash; 4:30 PM</dd>
          </div>
          <div class="flex justify-between">
            <dt>Wednesday</dt>
            <dd>8:00 AM &ndash; 4:30 PM</dd>
          </div>
          <div class="flex justify-between">
            <dt>Thursday</dt>
            <dd>8:00 AM &ndash; 4:30 PM</dd>
          </div>
          <div class="flex justify-between">
            <dt>Friday</dt>
            <dd>8:00 AM &ndash; 4:30 PM</dd>
          </div>
          <div class="flex justify-between">
            <dt>Saturday</dt>
            <dd>Closed</dd>
          </div>
          <div class="flex justify-between">
            <dt>Sunday</dt>
            <dd>Closed</dd>
          </div>
        </dl>
      </div>
      <div>
        <h3 class="text-2xl font-bold text-navy mb-6">Location</h3>
        <address class="not-italic text-body-text mb-4">
          <p class="font-medium text-navy">Planning &amp; Zoning Department</p>
          <p>125 Main Street, Suite 102</p>
          <p>Littleton, NH 03561</p>
        </address>
        <div
          class="bg-gray-200 h-48 rounded-lg flex items-center justify-center"
          role="img"
          aria-label="Map showing Planning and Zoning office location at 125 Main Street"
        >
          <span class="text-gray-500" aria-hidden="true">Map Placeholder</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Back to Departments -->
  <section class="py-8 bg-light-blue">
    <div class="max-w-7xl mx-auto px-8 text-center">
      <a
        href="/departments"
        class="inline-flex items-center gap-2 text-navy font-semibold hover:underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        Back to All Departments
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 1200px;
    margin: 48px auto;
    padding: 0 20px;
  }
  @media (max-width: 900px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .services-grid { grid-template-columns: 1fr; }
  }

  .service-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-top: 4px solid #2C4A7C;
    border-radius: 8px;
    padding: 24px;
  }

  /* Fixed: navy on white — passes 4.5:1 */
  .service-link {
    color: #1B2E4B;
    font-weight: 600;
    text-decoration: underline;
  }
  .service-link:hover { color: #2C4A7C; }
  .service-link:focus {
    outline: 2px solid #1B2E4B;
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* Fixed: navy on light-blue — passes 4.5:1 */
  .meeting-link {
    display: inline-block;
    margin-top: 1rem;
    color: #1B2E4B;
    font-weight: 600;
    text-decoration: underline;
  }
  .meeting-link:hover { color: #2C4A7C; }
  .meeting-link:focus {
    outline: 2px solid #1B2E4B;
    outline-offset: 2px;
    border-radius: 2px;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    max-width: 1200px;
    margin: 40px auto;
    padding: 0 32px;
  }
  @media (max-width: 900px) {
    .steps-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .steps-grid { grid-template-columns: 1fr; }
  }

  .meetings-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    max-width: 1200px;
    margin: 40px auto;
    padding: 0 32px;
  }
  @media (max-width: 768px) {
    .meetings-grid { grid-template-columns: 1fr; }
  }

  .info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 48px 20px;
  }
  @media (max-width: 768px) {
    .info-grid { grid-template-columns: 1fr; }
  }
</style>