---
import BaseLayout from '../../layouts/BaseLayout.astro';

const services = [
  { title: 'Books & Media', description: 'Thousands of books, DVDs, audiobooks, and magazines available for checkout.', icon: 'book' },
  { title: 'Digital Resources', description: 'Free access to eBooks, databases, and streaming services with your library card.', icon: 'tablet' },
  { title: "Children's Programs", description: 'Story time, summer reading, and educational activities for kids of all ages.', icon: 'users' },
  { title: 'Computer Access', description: 'Free public computers and WiFi for research, job searching, and more.', icon: 'monitor' },
  { title: 'Community Room', description: 'Meeting space available for community groups and nonprofit organizations.', icon: 'home' },
  { title: 'Interlibrary Loan', description: 'Request books and materials from libraries across New Hampshire and beyond.', icon: 'share' },
];

const programs = [
  { title: 'Story Time for Toddlers', day: 'Tuesdays', time: '10:00 AM', datetime: '2025-11-04T10:00', description: 'Interactive stories, songs, and activities for children ages 2–4 and their caregivers.' },
  { title: 'Adult Book Club', day: 'First Wednesday', time: '6:00 PM', datetime: '2025-11-05T18:00', description: 'Join fellow book lovers to discuss this month\'s selection. New members always welcome.' },
  { title: 'Computer Skills Workshop', day: 'Thursdays', time: '2:00 PM', datetime: '2025-11-06T14:00', description: 'Learn basic computer skills including email, internet safety, and document creation.' },
  { title: 'Teen Gaming Night', day: 'Last Friday', time: '4:00 PM', datetime: '2025-11-28T16:00', description: 'Video games, board games, and snacks for teens in grades 6–12.' },
];

const resources = [
  { title: 'OverDrive / Libby', description: 'Borrow eBooks and audiobooks on your phone, tablet, or computer.' },
  { title: 'NH State Library', description: 'Access research databases and educational resources statewide.' },
  { title: 'Ancestry Library', description: 'Explore genealogy records and family history research tools.' },
  { title: 'Mango Languages', description: 'Learn over 70 languages with interactive lessons and courses.' },
];

const hours = [
  { day: 'Monday', hours: '9:00 AM – 8:00 PM' },
  { day: 'Tuesday', hours: '9:00 AM – 8:00 PM' },
  { day: 'Wednesday', hours: '9:00 AM – 6:00 PM' },
  { day: 'Thursday', hours: '9:00 AM – 8:00 PM' },
  { day: 'Friday', hours: '9:00 AM – 5:00 PM' },
  { day: 'Saturday', hours: '9:00 AM – 4:00 PM' },
  { day: 'Sunday', hours: 'Closed' },
];
---

<BaseLayout title="Littleton Public Library | Town of Littleton, NH" description="Your community library offering books, digital resources, programs, and services for residents of all ages — free to all Littleton residents.">

  <!-- Hero -->
  <section class="bg-light-blue py-12" aria-labelledby="hero-heading">
    <div class="max-w-7xl mx-auto px-8">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-sm text-body-text list-none p-0 m-0">
          <li>
            <a href="/departments" class="hover:underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded">
              Departments
            </a>
          </li>
          <li aria-hidden="true">/</li>
          <li aria-current="page" class="text-navy font-medium">Library</li>
        </ol>
      </nav>
      <h1 id="hero-heading" class="text-4xl font-bold text-navy mb-4">Littleton Public Library</h1>
      <p class="text-lg text-body-text mb-6 max-w-3xl">
        Your community library offering books, digital resources, programs, and services for residents of all ages &mdash; free to all Littleton residents.
      </p>
      <div class="flex flex-wrap items-center gap-6 text-body-text">
        <a href="tel:+16035550107" class="flex items-center gap-2 underline hover:no-underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded" aria-label="Call library at (603) 555-0107">
          <svg class="w-5 h-5 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          (603) 555-0107
        </a>
        <a href="mailto:library@littletonnh.gov" class="flex items-center gap-2 underline hover:no-underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded" aria-label="Email library at library@littletonnh.gov">
          <svg class="w-5 h-5 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          library@littletonnh.gov
        </a>
        <a href="https://maps.google.com/?q=92+Main+Street+Littleton+NH" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 underline hover:no-underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded" aria-label="View 92 Main Street, Littleton NH on map (opens in new tab)">
          <svg class="w-5 h-5 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          92 Main Street, Littleton NH
        </a>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-16 bg-white" aria-labelledby="services-heading">
    <div class="max-w-7xl mx-auto px-8">
      <h2 id="services-heading" class="text-3xl font-bold text-navy mb-8 text-center">Library Services</h2>
      <div class="services-grid">
        {services.map((service) => (
          <article class="service-card">
            <div class="w-12 h-12 bg-light-blue rounded-full flex items-center justify-center mb-4">
              {service.icon === 'book' && (
                <svg class="w-6 h-6 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                </svg>
              )}
              {service.icon === 'tablet' && (
                <svg class="w-6 h-6 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
                </svg>
              )}
              {service.icon === 'users' && (
                <svg class="w-6 h-6 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
                </svg>
              )}
              {service.icon === 'monitor' && (
                <svg class="w-6 h-6 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              )}
              {service.icon === 'home' && (
                <svg class="w-6 h-6 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                </svg>
              )}
              {service.icon === 'share' && (
                <svg class="w-6 h-6 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
                </svg>
              )}
            </div>
            <h3 class="text-xl font-semibold text-navy mb-2">{service.title}</h3>
            <p class="text-body-text">{service.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Hours -->
  <section class="py-16 bg-light-blue" aria-labelledby="hours-heading">
    <div class="max-w-7xl mx-auto px-8">
      <h2 id="hours-heading" class="text-3xl font-bold text-navy mb-8 text-center">Library Hours</h2>
      <div class="hours-layout">
        <div class="bg-white rounded-lg p-6">
          <h3 class="sr-only">Weekly Hours</h3>
          <dl class="space-y-1">
            {hours.map((item) => (
              <div class="flex justify-between py-2 border-b border-gray-100 last:border-b-0">
                <dt class="font-medium text-navy">{item.day}</dt>
                <dd class="text-body-text">{item.hours}</dd>
              </div>
            ))}
          </dl>
        </div>
        <div>
          <div class="bg-white rounded-lg p-6 mb-6">
            <h3 class="text-xl font-semibold text-navy mb-3">Get Your Library Card</h3>
            <p class="text-body-text mb-3">
              Library cards are free for all Littleton residents. Visit us with a photo ID and proof of residency to get started.
            </p>
            <p class="text-body-text mb-4">
              <strong>Requirements:</strong> Littleton resident, valid photo ID
            </p>
            <a
              href="/contact"
              class="inline-flex items-center gap-2 bg-navy text-white px-6 py-3 rounded-lg font-semibold hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2"
              aria-label="Get a library card today"
            >
              Get a Card Today <span aria-hidden="true">→</span>
            </a>
          </div>
          <div class="bg-white rounded-lg p-6">
            <h3 class="text-xl font-semibold text-navy mb-3">Book a Room</h3>
            <p class="text-body-text mb-4">
              Our community room is available for meetings, workshops, and nonprofit events. Reserve your space today.
            </p>
            <a
              href="/contact"
              class="text-navy font-semibold hover:underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded"
              aria-label="Reserve the community room"
            >
              Reserve a Room <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Upcoming Programs -->
  <section class="py-16 bg-white" aria-labelledby="programs-heading">
    <div class="max-w-7xl mx-auto px-8">
      <h2 id="programs-heading" class="text-3xl font-bold text-navy mb-8 text-center">Upcoming Programs</h2>
      <div class="programs-grid">
        {programs.map((program) => (
          <article class="program-card">
            <p class="text-sm text-body-text mb-2">
              <time datetime={program.datetime}>{program.day} at {program.time}</time>
            </p>
            <h3 class="text-xl font-semibold text-navy mb-2">{program.title}</h3>
            <p class="text-body-text mb-4">{program.description}</p>
            <a
              href="/demo"
              class="text-navy font-semibold hover:underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded"
              aria-label={`Learn more about ${program.title}`}
            >
              Learn More <span aria-hidden="true">→</span>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Digital Resources -->
  <section class="py-16 bg-navy" aria-labelledby="resources-heading">
    <div class="max-w-7xl mx-auto px-8">
      <h2 id="resources-heading" class="text-3xl font-bold text-white mb-8 text-center">Free Digital Resources</h2>
      <div class="resources-grid">
        {resources.map((resource) => (
          <div class="resource-card">
            <h3 class="text-xl font-semibold text-white mb-2">{resource.title}</h3>
            <p class="text-white text-sm mb-4">{resource.description}</p>
            <a
              href="#"
              class="text-white font-semibold hover:underline focus:outline-none focus:ring-2 focus:ring-gold focus:ring-offset-2 rounded"
              aria-label={`Access ${resource.title}`}
            >
              Access Now <span aria-hidden="true">→</span>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Location -->
  <section class="py-16 bg-white" aria-labelledby="location-heading">
    <h2 id="location-heading" class="sr-only">Library Location</h2>
    <div class="info-grid">
      <div>
        <h3 class="text-2xl font-bold text-navy mb-6">Visit Us</h3>
        <div class="space-y-4">
          <a
            href="https://maps.google.com/?q=92+Main+Street+Littleton+NH"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-start gap-3 text-body-text underline hover:no-underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded"
            aria-label="View 92 Main Street, Littleton NH 03561 on map (opens in new tab)"
          >
            <svg class="w-5 h-5 mt-1 flex-shrink-0 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span>92 Main Street<br/>Littleton, NH 03561</span>
          </a>
          <a
            href="tel:+16035550107"
            class="flex items-center gap-3 text-body-text underline hover:no-underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded"
            aria-label="Call library at (603) 555-0107"
          >
            <svg class="w-5 h-5 flex-shrink-0 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            (603) 555-0107
          </a>
          <a
            href="mailto:library@littletonnh.gov"
            class="flex items-center gap-3 text-body-text underline hover:no-underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded"
            aria-label="Email library at library@littletonnh.gov"
          >
            <svg class="w-5 h-5 flex-shrink-0 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            library@littletonnh.gov
          </a>
        </div>
      </div>
      <div
        class="bg-gray-200 rounded-lg h-64 flex items-center justify-center"
        role="img"
        aria-label="Map showing Littleton Public Library location at 92 Main Street"
      >
        <span class="text-gray-500" aria-hidden="true">Map Placeholder</span>
      </div>
    </div>
  </section>

  <!-- Back to Departments -->
  <section class="py-8 bg-light-blue">
    <div class="max-w-7xl mx-auto px-8 text-center">
      <a
        href="/departments"
        class="inline-flex items-center gap-2 text-navy font-semibold hover:underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded"
      >
        <svg aria-hidden="true" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Back to All Departments
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  @media (max-width: 1024px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .services-grid { grid-template-columns: 1fr; }
  }

  .service-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-top: 4px solid #2C4A7C;
    border-radius: 8px;
    padding: 24px;
  }

  .hours-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    max-width: 1200px;
    margin: 40px auto;
    padding: 0 32px;
  }
  @media (max-width: 768px) {
    .hours-layout { grid-template-columns: 1fr; }
  }

  .programs-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    max-width: 1200px;
    margin: 40px auto;
    padding: 0 32px;
  }
  @media (max-width: 768px) {
    .programs-grid { grid-template-columns: 1fr; }
  }

  .program-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-left: 4px solid #C8973A;
    border-radius: 8px;
    padding: 24px;
  }

  .resources-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    max-width: 1200px;
    margin: 40px auto;
    padding: 0 32px;
  }
  @media (max-width: 768px) {
    .resources-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .resource-card {
    background-color: rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 24px;
  }

  .info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 48px 20px;
  }
  @media (max-width: 768px) {
    .info-grid { grid-template-columns: 1fr; }
  }
</style>