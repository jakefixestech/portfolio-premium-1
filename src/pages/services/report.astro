---
import BaseLayout from '../../layouts/BaseLayout.astro';

const categories = [
  { title: 'Pothole or Road Damage', dept: 'Public Works', phone: '(603) 555-0102', href: '/departments/public-works' },
  { title: 'Street Light Outage', dept: 'Public Works', phone: '(603) 555-0102', href: '/departments/public-works' },
  { title: 'Missed Trash Pickup', dept: 'Public Works', phone: '(603) 555-0102', href: '/departments/public-works' },
  { title: 'Water or Sewer Issue', dept: 'Public Works', phone: '(603) 555-0102', href: '/departments/public-works' },
  { title: 'Zoning Violation', dept: 'Planning & Zoning', phone: '(603) 555-0103', href: '/departments/planning-zoning' },
  { title: 'Animal Control', dept: 'Police Department', phone: '(603) 555-0104', href: '/departments/police' },
];
---

<BaseLayout title="Report a Problem | Town of Littleton, NH" description="Report road damage, utility issues, zoning violations, and other town concerns online.">

  <!-- Hero -->
  <section aria-labelledby="hero-heading" class="bg-light-blue py-12">
    <div class="max-w-7xl mx-auto px-8">
      <nav aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 text-sm text-body-text mb-4 list-none p-0 m-0">
          <li>
            <a href="/services" class="hover:underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded">
              Services
            </a>
          </li>
          <li aria-hidden="true">/</li>
          <li aria-current="page" class="text-navy font-medium">Report a Problem</li>
        </ol>
      </nav>
      <h2 id="hero-heading" class="text-4xl font-bold text-navy mb-4">Report a Problem</h2>
      <p class="text-lg text-body-text max-w-3xl">
        Let us know about road damage, utility issues, zoning violations, or other town concerns.
        We aim to respond within 2 business days.
      </p>
    </div>
  </section>

  <!-- Quick Report by Category -->
  <section aria-labelledby="categories-heading" class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-8">
      <h2 id="categories-heading" class="text-3xl font-bold text-navy text-center mb-8">Report by Category</h2>
      <div class="categories-grid">
        {categories.map((cat) => (
          <div class="category-card">
            <h3 class="text-lg font-bold text-navy mb-2">{cat.title}</h3>
            <p class="text-sm text-body-text mb-1">
              Department: <span class="font-medium text-navy">{cat.dept}</span>
            </p>
            <p class="text-sm text-body-text mb-3">
              Phone:
              <a
                href={`tel:+1${cat.phone.replace(/\D/g, '')}`}
                class="font-medium text-navy underline hover:no-underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded"
                aria-label={`Call ${cat.dept} at ${cat.phone}`}
              >
                {cat.phone}
              </a>
            </p>
            <a
              href={cat.href}
              class="text-navy text-sm font-semibold underline hover:no-underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded"
            >
              View Department <span aria-hidden="true">→</span>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Online Form -->
  <section aria-labelledby="form-heading" class="py-16 bg-light-blue">
    <div class="max-w-7xl mx-auto px-8">
      <h2 id="form-heading" class="text-3xl font-bold text-navy text-center mb-4">Submit a Report Online</h2>
      <p class="text-body-text text-center mb-8 max-w-2xl mx-auto">
        Not sure which department handles your issue? Use this form and we'll route it to the right team.
      </p>
      <div class="max-w-xl mx-auto">
        <p class="text-sm text-body-text mb-6">
          <span aria-hidden="true">*</span> Required field
        </p>
        <form action="#" method="post" novalidate class="space-y-6">

          <div>
            <label for="name" class="block text-sm font-semibold text-navy mb-2">
              Your Name <span aria-hidden="true" class="text-red-700">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              aria-required="true"
              autocomplete="name"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-semibold text-navy mb-2">
              Email Address <span aria-hidden="true" class="text-red-700">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              aria-required="true"
              autocomplete="email"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent"
            />
          </div>

          <div>
            <label for="category" class="block text-sm font-semibold text-navy mb-2">
              Problem Category <span aria-hidden="true" class="text-red-700">*</span>
            </label>
            <select
              id="category"
              name="category"
              required
              aria-required="true"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent bg-white"
            >
              <option value="">Select a category...</option>
              <option value="road">Pothole or Road Damage</option>
              <option value="streetlight">Street Light Outage</option>
              <option value="trash">Missed Trash Pickup</option>
              <option value="water">Water or Sewer Issue</option>
              <option value="zoning">Zoning Violation</option>
              <option value="animal">Animal Control</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div>
            <label for="location" class="block text-sm font-semibold text-navy mb-2">
              Location / Address <span aria-hidden="true" class="text-red-700">*</span>
            </label>
            <input
              type="text"
              id="location"
              name="location"
              required
              aria-required="true"
              placeholder="Street address or nearest intersection"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent"
            />
          </div>

          <div>
            <label for="description" class="block text-sm font-semibold text-navy mb-2">
              Description <span aria-hidden="true" class="text-red-700">*</span>
            </label>
            <textarea
              id="description"
              name="description"
              rows="5"
              required
              aria-required="true"
              placeholder="Please describe the problem in as much detail as possible..."
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent resize-y"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-navy text-white font-semibold py-3 px-6 rounded-lg hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2"
          >
            Submit Report
          </button>

        </form>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    max-width: 1200px;
    margin: 0 auto;
  }
  @media (max-width: 900px) {
    .categories-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .categories-grid { grid-template-columns: 1fr; }
  }

  .category-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-left: 4px solid #2C4A7C;
    border-radius: 4px;
    padding: 20px;
  }
</style>