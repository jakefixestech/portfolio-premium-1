---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Trash & Recycling | Town of Littleton, NH">
  <!-- Page Hero -->
  <section class="bg-light-blue py-12" aria-labelledby="hero-heading">
    <div class="max-w-7xl mx-auto px-8">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-sm text-body-text">
          <li><a href="/services" class="hover:text-navy focus:outline-none focus:ring-2 focus:ring-gold rounded">Services</a></li>
          <li><span aria-hidden="true">/</span></li>
          <li aria-current="page" class="text-navy font-medium">Trash & Recycling</li>
        </ol>
      </nav>
      <h1 id="hero-heading" class="text-4xl font-bold text-navy mb-4">Trash & Recycling</h1>
      <p class="text-lg text-body-text mb-6 max-w-3xl">
        Curbside collection, recycling guidelines, and waste disposal information for Littleton residents.
      </p>
      <div class="flex flex-wrap gap-4 text-body-text">
        <a href="tel:603-555-0102" class="flex items-center gap-2 hover:text-navy focus:outline-none focus:ring-2 focus:ring-gold rounded" aria-label="Call Public Works at 603-555-0102">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          Public Works: (603) 555-0102
        </a>
        <a href="mailto:publicworks@littletonnh.gov" class="flex items-center gap-2 hover:text-navy focus:outline-none focus:ring-2 focus:ring-gold rounded" aria-label="Email Public Works">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          publicworks@littletonnh.gov
        </a>
      </div>
    </div>
  </section>

  <!-- Collection Schedule -->
  <section class="py-16 bg-white" aria-labelledby="schedule-heading">
    <div class="max-w-7xl mx-auto px-8">
      <h2 id="schedule-heading" class="text-3xl font-bold text-navy text-center mb-8">Collection Schedule</h2>
      <div class="schedule-grid">
        <div class="bg-light-blue p-8 rounded-lg">
          <h3 class="text-xl font-bold text-navy mb-4">Trash Collection</h3>
          <ul class="space-y-3 text-body-text">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-mid-blue mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              Every week, Monday and Thursday
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-mid-blue mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              Set out by 7:00 AM
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-mid-blue mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              Containers may be placed at curb night before
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-mid-blue mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              Maximum 4 bags or containers per pickup
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-mid-blue mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              Extra bags require $2 sticker
            </li>
          </ul>
        </div>
        <div class="bg-light-blue p-8 rounded-lg">
          <h3 class="text-xl font-bold text-navy mb-4">Recycling Collection</h3>
          <ul class="space-y-3 text-body-text">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-mid-blue mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              Every other week, same day as trash
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-mid-blue mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              Blue bin provided by town
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-mid-blue mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              Rinse containers before recycling
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-mid-blue mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              No plastic bags in recycling bin
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-mid-blue mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              Next pickup dates listed below
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- What Goes Where -->
  <section class="py-16 bg-light-blue" aria-labelledby="waste-heading">
    <div class="max-w-7xl mx-auto px-8">
      <h2 id="waste-heading" class="text-3xl font-bold text-navy text-center mb-8">What Goes Where</h2>
      <div class="waste-grid">
        <div class="bg-white p-6 rounded-lg border-t-4" style="border-top-color: #1B2E4B;">
          <h3 class="text-lg font-bold text-navy mb-4 flex items-center gap-2">
            <span class="text-navy" aria-hidden="true">✓</span>
            Accepted in Recycling
          </h3>
          <ul class="space-y-2 text-body-text">
            <li>Paper and cardboard</li>
            <li>Glass bottles and jars</li>
            <li>Plastic bottles #1 and #2</li>
            <li>Aluminum and steel cans</li>
            <li>Flattened cardboard boxes</li>
          </ul>
        </div>
        <div class="bg-white p-6 rounded-lg border-t-4" style="border-top-color: #DC2626;">
          <h3 class="text-lg font-bold text-navy mb-4 flex items-center gap-2">
            <span class="text-red-600" aria-hidden="true">✗</span>
            Not Accepted in Recycling
          </h3>
          <ul class="space-y-2 text-body-text">
            <li>Plastic bags</li>
            <li>Styrofoam</li>
            <li>Food-soiled containers</li>
            <li>Electronics</li>
            <li>Hazardous materials</li>
          </ul>
        </div>
        <div class="bg-white p-6 rounded-lg border-t-4 border-gold">
          <h3 class="text-lg font-bold text-navy mb-4">Special Disposal Required</h3>
          <ul class="space-y-2 text-body-text">
            <li>Electronics (eWaste events)</li>
            <li>Hazardous household waste</li>
            <li>Appliances (call for pickup)</li>
            <li>Tires (transfer station)</li>
            <li>Paint (retailer take-back)</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Transfer Station -->
  <section class="py-16 bg-white" aria-labelledby="transfer-heading">
    <div class="max-w-7xl mx-auto px-8">
      <h2 id="transfer-heading" class="text-3xl font-bold text-navy text-center mb-8">Transfer Station</h2>
      <div class="schedule-grid">
        <div>
          <h3 class="text-xl font-bold text-navy mb-4">Hours</h3>
          <dl class="space-y-2 text-body-text">
            <div class="flex justify-between py-2 border-b border-gray-200">
              <dt class="font-medium">Tuesday</dt>
              <dd>7:00 AM – 3:00 PM</dd>
            </div>
            <div class="flex justify-between py-2 border-b border-gray-200">
              <dt class="font-medium">Thursday</dt>
              <dd>7:00 AM – 3:00 PM</dd>
            </div>
            <div class="flex justify-between py-2 border-b border-gray-200">
              <dt class="font-medium">Saturday</dt>
              <dd>7:00 AM – 3:00 PM</dd>
            </div>
            <div class="flex justify-between py-2 border-b border-gray-200">
              <dt class="font-medium">Sunday – Monday</dt>
              <dd>Closed</dd>
            </div>
            <div class="flex justify-between py-2">
              <dt class="font-medium">Wednesday & Friday</dt>
              <dd>Closed</dd>
            </div>
          </dl>
        </div>
        <div>
          <h3 class="text-xl font-bold text-navy mb-4">Accepted Items</h3>
          <ul class="space-y-3 text-body-text">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-mid-blue mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              Bulky waste and furniture
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-mid-blue mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              Yard waste and brush
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-mid-blue mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              Metal and appliances
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-mid-blue mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              Electronics (fee may apply)
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-mid-blue mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              Construction debris (fee)
            </li>
          </ul>
          <p class="mt-6 text-body-text">
            <strong class="text-navy">Address:</strong> 200 Industrial Park Road
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Upcoming Holidays -->
  <section class="py-16 bg-light-blue" aria-labelledby="holiday-heading">
    <div class="max-w-7xl mx-auto px-8">
      <h2 id="holiday-heading" class="text-3xl font-bold text-navy text-center mb-8">Holiday Collection Schedule</h2>
      <div class="overflow-x-auto">
        <table class="mx-auto bg-white rounded-lg overflow-hidden">
          <caption class="sr-only">Holiday collection schedule changes</caption>
          <thead class="bg-navy text-white">
            <tr>
              <th scope="col" class="px-6 py-4 text-left font-semibold">Holiday</th>
              <th scope="col" class="px-6 py-4 text-left font-semibold">Date</th>
              <th scope="col" class="px-6 py-4 text-left font-semibold">Collection Change</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <tr>
              <td class="px-6 py-4 text-body-text">Thanksgiving</td>
              <td class="px-6 py-4 text-body-text">
                <time datetime="2025-11-27">November 27, 2025</time>
              </td>
              <td class="px-6 py-4 text-body-text">Thursday collection moved to Friday</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 text-body-text">Christmas</td>
              <td class="px-6 py-4 text-body-text">
                <time datetime="2025-12-25">December 25, 2025</time>
              </td>
              <td class="px-6 py-4 text-body-text">Thursday collection moved to Friday</td>
            </tr>
            <tr>
              <td class="px-6 py-4 text-body-text">New Year's Day</td>
              <td class="px-6 py-4 text-body-text">
                <time datetime="2026-01-01">January 1, 2026</time>
              </td>
              <td class="px-6 py-4 text-body-text">Thursday collection moved to Friday</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Contact & Report -->
  <section class="py-16 bg-white" aria-labelledby="contact-heading">
    <div class="max-w-7xl mx-auto px-8">
      <h2 id="contact-heading" class="sr-only">Contact Public Works</h2>
      <div class="contact-grid">
        <div class="bg-light-blue p-6 rounded-lg">
          <h3 class="text-xl font-bold text-navy mb-4">Report a Missed Pickup</h3>
          <p class="text-body-text mb-4">Contact Public Works within 24 hours of your scheduled pickup.</p>
          <div class="space-y-2">
            <a 
              href="tel:603-555-0102" 
              class="flex items-center gap-2 text-body-text hover:text-navy focus:outline-none focus:ring-2 focus:ring-gold rounded"
              aria-label="Call Public Works at 603-555-0102"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              (603) 555-0102
            </a>
            <a 
              href="mailto:publicworks@littletonnh.gov" 
              class="flex items-center gap-2 text-body-text hover:text-navy focus:outline-none focus:ring-2 focus:ring-gold rounded"
              aria-label="Email Public Works"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              publicworks@littletonnh.gov
            </a>
          </div>
        </div>
        <div class="bg-light-blue p-6 rounded-lg">
          <h3 class="text-xl font-bold text-navy mb-4">Request Extra Pickup</h3>
          <p class="text-body-text mb-4">For large items or bulk waste removal, contact Public Works to schedule a special pickup.</p>
          <a 
            href="/departments/public-works" 
            class="inline-flex items-center gap-2 bg-navy text-white px-6 py-3 rounded font-semibold hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-gold focus:ring-offset-2"
            aria-label="Contact Public Works for extra pickup"
          >
            Contact Public Works
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .schedule-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    max-width: 1200px;
    margin: 40px auto;
    padding: 0 32px;
  }

  @media (max-width: 768px) {
    .schedule-grid {
      grid-template-columns: 1fr;
    }
  }

  .waste-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 1200px;
    margin: 40px auto;
    padding: 0 32px;
  }

  @media (max-width: 900px) {
    .waste-grid {
      grid-template-columns: 1fr;
    }
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    max-width: 800px;
    margin: 40px auto;
    padding: 0 32px;
  }

  @media (max-width: 600px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
