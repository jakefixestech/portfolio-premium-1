---
import BaseLayout from '../../layouts/BaseLayout.astro';

const permits = [
  { title: 'Building Permit', dept: 'Planning & Zoning', description: 'Required for new construction, additions, and major renovations.', href: '/departments/planning-zoning' },
  { title: 'Zoning Permit', dept: 'Planning & Zoning', description: 'Required for any change in land use or new structure.', href: '/departments/planning-zoning' },
  { title: 'Business License', dept: 'Town Clerk', description: 'Required to operate a business within Littleton town limits.', href: '/departments/town-clerk' },
  { title: 'Special Event Permit', dept: 'Town Clerk', description: 'Required for public events, road closures, and gatherings over 50 people.', href: '/departments/town-clerk' },
  { title: 'Driveway Permit', dept: 'Public Works', description: 'Required for new driveways or modifications to existing curb cuts.', href: '/departments/public-works' },
  { title: 'Sign Permit', dept: 'Planning & Zoning', description: 'Required for new commercial signage or modifications to existing signs.', href: '/demo' },
];
---

<BaseLayout title="Permits & Licenses | Town of Littleton, NH" description="Apply for building permits, business licenses, and other town permits in Littleton, New Hampshire.">

  <!-- Hero -->
  <section aria-labelledby="hero-heading" class="bg-light-blue py-12">
    <div class="max-w-7xl mx-auto px-8">
      <nav aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 text-sm text-body-text mb-4 list-none p-0 m-0">
          <li>
            <a href="/services" class="hover:underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded">
              Services
            </a>
          </li>
          <li aria-hidden="true">/</li>
          <li aria-current="page" class="text-navy font-medium">Permits &amp; Licenses</li>
        </ol>
      </nav>
      <h1 id="hero-heading" class="text-4xl font-bold text-navy mb-4">Permits &amp; Licenses</h1>
      <p class="text-lg text-body-text max-w-3xl">
        Find the right permit or license for your project. Most permits are handled through
        Planning &amp; Zoning or the Town Clerk's office.
      </p>
    </div>
  </section>

  <!-- Permits Grid -->
  <section aria-labelledby="permits-heading" class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-8">
      <h2 id="permits-heading" class="text-3xl font-bold text-navy text-center mb-8">Common Permits &amp; Licenses</h2>
      <div class="permits-grid">
        {permits.map((permit) => (
          <article class="permit-card">
            <h3 class="text-xl font-bold text-navy mb-1">{permit.title}</h3>
            <p class="text-sm text-body-text mb-3">
              Handled by: <span class="font-semibold text-navy">{permit.dept}</span>
            </p>
            <p class="text-body-text text-sm mb-4">{permit.description}</p>
            <a
              href={permit.href}
              class="text-navy font-semibold underline hover:no-underline focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 rounded"
              aria-label={`Learn more about ${permit.title}`}
            >
              Learn More <span aria-hidden="true">→</span>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section aria-labelledby="contact-heading" class="py-16 bg-light-blue">
    <div class="max-w-3xl mx-auto px-8 text-center">
      <h2 id="contact-heading" class="text-3xl font-bold text-navy mb-4">Not Sure What You Need?</h2>
      <p class="text-body-text mb-8 leading-relaxed">
        Contact the Planning &amp; Zoning Department or Town Clerk's office and we'll help you
        determine which permits apply to your project.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/departments/planning-zoning"
          class="inline-block bg-navy text-white font-semibold px-6 py-3 rounded hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2"
        >
          Planning &amp; Zoning <span aria-hidden="true">→</span>
        </a>
        <a
          href="/departments/town-clerk"
          class="inline-block border-2 border-navy text-navy font-semibold px-6 py-3 rounded hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2"
        >
          Town Clerk <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .permits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 1200px;
    margin: 0 auto;
  }
  @media (max-width: 900px) {
    .permits-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .permits-grid { grid-template-columns: 1fr; }
  }

  .permit-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-top: 4px solid #2C4A7C;
    border-radius: 8px;
    padding: 24px;
  }
</style>