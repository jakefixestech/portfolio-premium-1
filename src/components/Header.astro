---
const navItems = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Departments', href: '/departments' },
  { label: 'Government', href: '/government' },
  { label: 'Services', href: '/services' },
  { label: 'News', href: '/news' },
  { label: 'Calendar', href: '/calendar' },
  { label: 'Contact', href: '/contact' },
];
---

<a href="#main-content" class="skip-link">
  Skip to main content
</a>

<header class="site-header">
  <div class="header-top">
    <div class="max-w-7xl mx-auto px-4 py-6">
      <div class="text-center">
        <p class="header-title">
          <span class="header-town-of">Town of</span>
          <span class="header-littleton">Littleton</span>
        </p>
        <p class="header-subtitle">New Hampshire &bull; White Mountains Region</p>
      </div>
    </div>
  </div>

  <nav class="header-nav" aria-label="Main navigation">
    <div class="max-w-7xl mx-auto px-4 py-2">
      <ul class="flex flex-wrap justify-center gap-1 md:gap-2 list-none m-0 p-0">
        {navItems.map((item, index) => (
          <li class="flex items-center">
            <a href={item.href} class="nav-link px-3 py-2 text-sm md:text-base rounded">
              {item.label}
            </a>
            {index < navItems.length - 1 && (
              <span class="nav-divider hidden md:inline" aria-hidden="true">|</span>
            )}
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<style>
  /*
    ── FONT FALLBACK METRIC MATCHING ─────────────────────────────────
    These @font-face declarations create local "adjusted" versions of
    the system fallback fonts. size-adjust, ascent-override, and
    descent-override are tuned so Georgia (Playfair fallback) and
    Georgia (Source Serif fallback) occupy the same line-box dimensions
    as the web fonts. This means zero layout shift when the Google Fonts
    swap in — the text takes up exactly the same space before and after.

    Values derived by comparing Playfair Display and Source Serif 4
    metrics against Georgia's default metrics.
  ────────────────────────────────────────────────────────────────── */

  @font-face {
    font-family: 'Playfair-Fallback';
    src: local('Georgia');
    size-adjust: 97%;
    ascent-override: 92%;
    descent-override: 24%;
    line-gap-override: 0%;
  }

  @font-face {
    font-family: 'SourceSerif-Fallback';
    src: local('Georgia');
    size-adjust: 96%;
    ascent-override: 90%;
    descent-override: 22%;
    line-gap-override: 0%;
  }

  /* ── Skip link ───────────────────────────────────────────────── */

  .skip-link {
    position: absolute;
    top: -40px;
    left: 0;
    background: #1B2E4B;
    color: white;
    padding: 8px 16px;
    z-index: 100;
    text-decoration: none;
    font-weight: 600;
  }
  .skip-link:focus { top: 0; }

  /* ── Header shell ────────────────────────────────────────────── */

  .site-header {
    background: white;
    border-bottom: 3px solid #A67A28;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }

  .header-top {
    border-bottom: 1px solid #e5e7eb;
  }

  /* ── Header title ────────────────────────────────────────────── */

  .header-title {
    /*
      Use the metric-matched fallback first so the layout is stable
      while Playfair Display downloads. When the web font arrives the
      swap is invisible because both fonts occupy the same space.
    */
    font-family: 'Playfair Display', 'Playfair-Fallback', Georgia, serif;
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.5rem;
    line-height: 1.1;
  }

  .header-town-of {
    font-size: 1.75rem;
    font-weight: 400;
    color: #1B2E4B;
    letter-spacing: 0.03em;
  }

  .header-littleton {
    font-size: 4.5rem;
    font-weight: 800;
    color: #A67A28;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .header-subtitle {
    /*
      Same metric-matching approach for Source Serif 4.
    */
    font-family: 'Source Serif 4', 'SourceSerif-Fallback', Georgia, serif;
    font-size: 0.875rem;
    color: #2C4A7C;
    margin-top: 0.375rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 400;
  }

  /* ── Nav ─────────────────────────────────────────────────────── */

  .header-nav {
    background: #1B2E4B;
  }

  .nav-link {
    font-family: 'Source Serif 4', 'SourceSerif-Fallback', Georgia, serif;
    color: rgba(255,255,255,0.9);
    text-decoration: none;
    font-weight: 600;
    transition: color 0.2s;
    letter-spacing: 0.02em;
  }

  .nav-link:hover { color: #A67A28; }

  .nav-link:focus {
    outline: 2px solid #A67A28;
    outline-offset: 2px;
  }

  .nav-divider { color: rgba(255,255,255,0.6); }

  /* ── Responsive ──────────────────────────────────────────────── */

  @media (max-width: 640px) {
    .header-town-of { font-size: 1.25rem; }
    .header-littleton { font-size: 3rem; }
  }
</style>