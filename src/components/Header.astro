---
const navItems = [
  { label: 'About', href: '/about' },
  { label: 'Departments', href: '/departments' },
  { label: 'Government', href: '/government' },
  { label: 'Services', href: '/services' },
  { label: 'News', href: '/news' },
  { label: 'Calendar', href: '/calendar' },
  { label: 'Contact', href: '/contact' },
];
---

<a href="#main-content" class="skip-link">
  Skip to main content
</a>

<header class="site-header">
  <div class="header-top">
    <div class="max-w-7xl mx-auto px-4 py-6">
      <div class="text-center">
        <a href="/" class="header-home-link" aria-label="Town of Littleton, NH - Home">
          <p class="header-title">
            <span class="header-town-of">Town of</span>
            <span class="header-littleton">Littleton</span>
          </p>
          <p class="header-subtitle">New Hampshire &bull; White Mountains Region</p>
        </a>
      </div>
    </div>
  </div>

  <nav class="header-nav" aria-label="Main navigation">
    <div class="nav-inner max-w-7xl mx-auto px-4">

      <!-- Hamburger button — hidden on desktop, visible ≤900px -->
      <button
        class="nav-toggle"
        id="nav-toggle"
        aria-expanded="false"
        aria-controls="nav-menu"
        aria-label="Open navigation menu"
      >
        <span class="hamburger-icon" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
        <span class="nav-toggle-label" id="nav-toggle-label">Menu</span>
      </button>

      <!-- Nav link list -->
      <ul class="nav-list" id="nav-menu" role="list">
        {navItems.map((item, index) => (
          <li class="nav-item">
            <a href={item.href} class="nav-link">
              {item.label}
            </a>
            {index < navItems.length - 1 && (
              <span class="nav-divider" aria-hidden="true">|</span>
            )}
          </li>
        ))}

        <!-- Search form — inline on desktop, stacked on mobile -->
        <li class="nav-item nav-search-item" role="none">
          <form action="/search" method="get" role="search" class="nav-search-form">
            <label for="nav-search" class="sr-only">Search Town of Littleton</label>
            <input
              type="search"
              id="nav-search"
              name="q"
              placeholder="Search..."
              autocomplete="off"
              class="nav-search-input"
            />
            <button type="submit" class="nav-search-btn" aria-label="Submit search">
              <svg class="w-4 h-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <circle cx="11" cy="11" r="8"/>
                <path d="M21 21l-4.35-4.35"/>
              </svg>
            </button>
          </form>
        </li>
      </ul>

    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu   = document.getElementById('nav-menu');
  const label  = document.getElementById('nav-toggle-label');

  if (toggle && menu && label) {
    toggle.addEventListener('click', () => {
      const opening = toggle.getAttribute('aria-expanded') !== 'true';
      toggle.setAttribute('aria-expanded', String(opening));
      toggle.setAttribute('aria-label', opening ? 'Close navigation menu' : 'Open navigation menu');
      label.textContent = opening ? 'Close' : 'Menu';
      menu.classList.toggle('nav-list--open', opening);
      toggle.classList.toggle('nav-toggle--open', opening);
    });

    menu.querySelectorAll('.nav-link').forEach(link => {
      link.addEventListener('click', () => {
        toggle.setAttribute('aria-expanded', 'false');
        toggle.setAttribute('aria-label', 'Open navigation menu');
        label.textContent = 'Menu';
        menu.classList.remove('nav-list--open');
        toggle.classList.remove('nav-toggle--open');
      });
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu.classList.contains('nav-list--open')) {
        toggle.setAttribute('aria-expanded', 'false');
        toggle.setAttribute('aria-label', 'Open navigation menu');
        label.textContent = 'Menu';
        menu.classList.remove('nav-list--open');
        toggle.classList.remove('nav-toggle--open');
        toggle.focus();
      }
    });
  }
</script>

<style>
  @font-face {
    font-family: 'Playfair-Fallback';
    src: local('Georgia');
    size-adjust: 97%;
    ascent-override: 92%;
    descent-override: 24%;
    line-gap-override: 0%;
  }

  @font-face {
    font-family: 'SourceSerif-Fallback';
    src: local('Georgia');
    size-adjust: 96%;
    ascent-override: 90%;
    descent-override: 22%;
    line-gap-override: 0%;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .skip-link {
    position: absolute;
    top: -40px;
    left: 0;
    background: #1B2E4B;
    color: white;
    padding: 8px 16px;
    z-index: 100;
    text-decoration: none;
    font-weight: 600;
  }
  .skip-link:focus { top: 0; }

  .site-header {
    background: white;
    border-bottom: 3px solid #A67A28;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }

  .header-top {
    border-bottom: 1px solid #e5e7eb;
  }

  .header-home-link {
    display: inline-block;
    text-decoration: none;
    border-radius: 4px;
  }
  .header-home-link:focus {
    outline: 2px solid #A67A28;
    outline-offset: 4px;
  }
  .header-home-link:hover .header-littleton {
    opacity: 0.85;
  }

  .header-title {
    font-family: 'Playfair Display', 'Playfair-Fallback', Georgia, serif;
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.5rem;
    line-height: 1.1;
  }

  .header-town-of {
    font-size: 1.75rem;
    font-weight: 400;
    color: #1B2E4B;
    letter-spacing: 0.03em;
  }

  .header-littleton {
    font-size: 4.5rem;
    font-weight: 800;
    color: #A67A28;
    letter-spacing: -0.02em;
    line-height: 1;
    transition: opacity 0.2s;
  }

  .header-subtitle {
    font-family: 'Source Serif 4', 'SourceSerif-Fallback', Georgia, serif;
    font-size: 0.875rem;
    color: #2C4A7C;
    margin-top: 0.375rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 400;
  }

  .header-nav {
    background: #1B2E4B;
    position: relative;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
  }

  .nav-list {
    display: flex;
    flex-wrap: nowrap;
    justify-content: center;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0.375rem 0;
    gap: 0;
  }

  .nav-item {
    display: flex;
    align-items: center;
  }

  .nav-link {
    font-family: 'Source Serif 4', 'SourceSerif-Fallback', Georgia, serif;
    color: rgba(255,255,255,0.9);
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    padding: 0.5rem 0.75rem;
    border-radius: 4px;
    transition: color 0.2s;
    letter-spacing: 0.02em;
    display: block;
  }
  .nav-link:hover { color: #A67A28; }
  .nav-link:focus {
    outline: 2px solid #A67A28;
    outline-offset: 2px;
  }

  .nav-divider {
    color: rgba(255,255,255,0.6);
    padding: 0 2px;
    user-select: none;
  }

  /* Search form in nav */
  .nav-search-item {
    margin-left: 0.75rem;
  }

  .nav-search-form {
    display: flex;
    align-items: center;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.3);
    border-radius: 6px;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .nav-search-form:focus-within {
    border-color: #A67A28;
    background: rgba(255,255,255,0.18);
  }

  .nav-search-input {
    background: transparent;
    border: none;
    outline: none;
    color: white;
    font-family: 'Source Serif 4', 'SourceSerif-Fallback', Georgia, serif;
    font-size: 0.9rem;
    padding: 0.375rem 0.625rem;
    width: 130px;
    transition: width 0.2s;
  }
  .nav-search-input::placeholder {
    color: rgba(255,255,255,0.55);
  }
  .nav-search-input:focus {
    width: 180px;
  }

  .nav-search-btn {
    background: #A67A28;
    border: none;
    color: white;
    padding: 0.375rem 0.625rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    height: 100%;
  }
  .nav-search-btn:hover { background: #8a6420; }
  .nav-search-btn:focus {
    outline: 2px solid white;
    outline-offset: -2px;
  }

  .nav-toggle { display: none; }

  /* ── Mobile / Tablet ≤900px ──────────────────────────────────── */
  @media (max-width: 900px) {

    .nav-inner {
      justify-content: flex-end;
      padding: 0 0.5rem;
    }

    .nav-toggle {
      display: flex;
      align-items: center;
      gap: 8px;
      background: none;
      border: 2px solid rgba(255,255,255,0.5);
      border-radius: 6px;
      color: white;
      padding: 8px 14px;
      margin: 6px 0;
      cursor: pointer;
      font-family: 'Source Serif 4', 'SourceSerif-Fallback', Georgia, serif;
      font-size: 0.95rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      transition: border-color 0.2s, background 0.2s;
    }
    .nav-toggle:hover {
      border-color: white;
      background: rgba(255,255,255,0.08);
    }
    .nav-toggle:focus {
      outline: 2px solid #A67A28;
      outline-offset: 2px;
    }

    .hamburger-icon {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 4px;
      width: 20px;
      height: 16px;
      flex-shrink: 0;
    }
    .hamburger-icon span {
      display: block;
      width: 100%;
      height: 2px;
      background: white;
      border-radius: 2px;
      transition: transform 0.25s ease, opacity 0.2s ease;
      transform-origin: center;
    }

    .nav-toggle--open .hamburger-icon span:nth-child(1) {
      transform: translateY(6px) rotate(45deg);
    }
    .nav-toggle--open .hamburger-icon span:nth-child(2) {
      opacity: 0;
      transform: scaleX(0);
    }
    .nav-toggle--open .hamburger-icon span:nth-child(3) {
      transform: translateY(-6px) rotate(-45deg);
    }

    .nav-list {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      z-index: 50;
      background: #1B2E4B;
      flex-direction: column;
      align-items: stretch;
      padding: 0.5rem 0 1rem;
      border-top: 2px solid #A67A28;
      box-shadow: 0 8px 24px rgba(0,0,0,0.25);
    }

    .nav-list--open { display: flex; }

    .nav-item {
      flex-direction: column;
      align-items: stretch;
    }

    .nav-link {
      font-size: 1.05rem;
      padding: 0.875rem 1.5rem;
      border-radius: 0;
      border-bottom: 1px solid rgba(255,255,255,0.08);
      letter-spacing: 0.03em;
    }
    .nav-link:hover {
      background: rgba(255,255,255,0.06);
      color: #A67A28;
    }

    .nav-divider { display: none; }

    /* Search on mobile — full width in dropdown */
    .nav-search-item {
      margin-left: 0;
      padding: 0.75rem 1.5rem;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .nav-search-form {
      width: 100%;
    }

    .nav-search-input {
      width: 100%;
      font-size: 1rem;
      padding: 0.5rem 0.75rem;
    }
    .nav-search-input:focus {
      width: 100%;
    }

    .nav-search-btn {
      padding: 0.5rem 0.875rem;
    }
  }

  @media (max-width: 640px) {
    .header-town-of { font-size: 1.25rem; }
    .header-littleton { font-size: 3rem; }
  }
</style>